#!/bin/sh

# coder: Lightweight conversational client
# Connects to the centralized coder-server (Intelligence Proxy)

SCRIPT_DIR=$(dirname "$(realpath "$0")")
. "$SCRIPT_DIR/etc/coder.conf"

API_URL="http://${HOST}:${PORT}/v1/chat/completions"

# Check if server is running
if ! curl -s -o /dev/null -w '%{http_code}' "http://${HOST}:${PORT}/health" 2>/dev/null | grep -E '200|404|503' > /dev/null; then
    if ! curl -s -o /dev/null -w '%{http_code}' "${LLAMA_URL}/health" 2>/dev/null | grep -E '200|503' > /dev/null; then
        echo "Auto-starting coder-server in the background..."
        "$SCRIPT_DIR/coder-server" > "$SCRIPT_DIR/var/log/server.log" 2>&1 &
        SERVER_PID=$!
        
        printf "Waiting for server to spin up"
        for i in $(seq 1 120); do
            # Wait for either proxy 404 (alive) or llama-server 200/503 (loading)
            if curl -s -o /dev/null -w '%{http_code}' "http://${HOST}:${PORT}/health" 2>/dev/null | grep -E '200|404|503' > /dev/null; then
                echo " ready!"
                break
            fi
            printf "."
            sleep 1
            if [ $i -eq 120 ]; then
                echo " timeout! Check var/log/server.log"
                exit 1
            fi
        done
    fi
fi

SYSTEM_PROMPT="You are a brilliant, expert software engineer using FreeBSD. You provide concise, direct, and incredibly intelligent answers."

# Pass execution to our simple Lua chat client
export CODER_API_URL="$API_URL"
export CODER_SYSTEM_PROMPT="$SYSTEM_PROMPT"
exec luajit "$SCRIPT_DIR/lib/chat.lua" "$@"
