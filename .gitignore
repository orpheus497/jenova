# --- Jenova CLI (external checkout — downloaded at runtime, not tracked or a submodule) ---
/jenova-cli/*
!/jenova-cli/.gitkeep

# --- Build Artifacts ---
/public/
/bin/jenova-desktop
/bin/jenova-ui
/jenova-ui/jenova-ui
/external/llama.cpp/build/

# Compiled llama.cpp artifacts (platform-specific — always built from source)
/bin/llama-*
!/bin/build-llama
/bin/llama
/bin/test-*
/bin/export-graph-ops
/bin/lib*.so*
/bin/lib*.dylib*


/cli-agent/build/
/cli-agent/build_test/
# Bundled jvim editor — build & install artifacts
/jvim/build/
/jvim/install/
/jvim/.deps/
/jvim/cmake-build-*/
*.o
*.so
*.a
*.dylib

# --- Models (never upload multi-GB LLM weights) ---
*.gguf
/models/**/*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.h5
*.tflite
!/models/.gitkeep
!/models/**/.gitkeep
!/models/README.md

# --- Runtime Data ---
/var/log/**
/var/cache/**
!/var/log/.gitkeep
!/var/cache/.gitkeep

# --- Jenova Runtime (Private Data) ---
/.jenova/
/.system/
/.crush/
/var/state/

# --- Temporary Search & Discovery Artifacts ---
/var/cache/find_results.tmp
/var/cache/workspaces.tmp
/var/cache/storage.tmp

# --- Backups (local-only snapshots) ---
/backups/

# --- AI Agent / Assistant Data (chat history, session data, dev docs) ---
.claude/
.crush/
.gemini/
.jenova/
.cursor/
.copilot/
.codeium/
.aider/
.continue/
.tabnine/
.windsurf/

