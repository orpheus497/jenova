# --- Jenova CLI (external checkout — downloaded at runtime, not tracked or a submodule) ---
/jenova-cli/*
!/jenova-cli/.gitkeep

# --- Build Artifacts ---
/llama.cpp/build/
/llama.cpp/bin/
/cli-agent/build/
/cli-agent/build_test/
# Bundled jvim editor — build & install artifacts
/jvim/build/
/jvim/install/
/jvim/.deps/
/jvim/cmake-build-*/
*.o
*.so
*.a
*.dylib

# --- Models (never upload multi-GB LLM weights) ---
*.gguf
/models/**/*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.h5
*.tflite
!/models/.gitkeep
!/models/**/.gitkeep
!/models/README.md

# --- Runtime Data ---
/var/log/**
/var/cache/**
!/var/log/.gitkeep
!/var/cache/.gitkeep

# --- Jenova Runtime (Private Data) ---
/.jenova/

# --- Backups (local-only snapshots) ---
/backups/

# --- AI Agent / Assistant Data (chat history, session data, dev docs) ---
.claude/
.crush/
.gemini/
.cursor/
.copilot/
.codeium/
.aider/
.continue/
.tabnine/
.windsurf/

# --- Environment, Keys & Secrets ---
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
id_rsa
id_ed25519
*.secret
*_secret*
*.token
credentials.json
secrets.json
auth.json

# --- System & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml
*~
*.swp
*.swo
\#*\#

# --- Configuration (local overrides) ---
/etc/jenova.conf.local
/etc/jenova.conf.bak.*
/etc/jenova.local.conf

# --- User / Session Data (chat history, memory, training data) ---
*.sqlite
*.sqlite3
*.db
*.jsonl
.bash_history
.zsh_history
.history

# --- Large / temporary files ---
*.log
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.bak
*.tmp
core
core.*
*.dmp
nul
