#!/bin/sh

# jenova-setup: One-time system configuration for Jenova Cognitive Architecture
# Hardware: macOS Apple Silicon with Metal GPU acceleration
# Run with: sudo ./jenova-setup
#
# Configures:
#   - Memory pressure monitoring for unified memory
#   - Metal Performance Shaders optimization
#   - CPU/GPU affinity settings
#
# Hardware context:
#   Apple Silicon uses unified memory architecture where CPU and GPU
#   share the same memory pool. This eliminates data transfer overhead
#   but requires careful memory management to avoid pressure.

set -e

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (sudo ./jenova-setup)"
    exit 1
fi

echo "=== jenova-setup: configuring macOS for Jenova CA ==="
echo "=== Hardware: Apple Silicon with Metal GPU ==="
echo ""

CHANGED=0

# Helper: check if a launch daemon is loaded
launchctl_check() {
    _label="$1"
    if launchctl list | grep -q "$_label" 2>/dev/null; then
        echo "[ok]  $_label is loaded"
        return 0
    else
        echo "[missing] $_label not loaded"
        return 1
    fi
}

# macOS memory optimizations for unified memory
echo "Configuring memory management for unified memory..."

# Set memory pressure handling
if ! sysctl kern.memorystatus_vm_pressure_level 2>/dev/null | grep -q "4"; then
    echo "Setting memory pressure level for better unified memory handling..."
    # Note: This would require a kernel extension or system configuration
    # For now, we'll document the recommendation
    echo "[info] Consider enabling memory pressure monitoring in Activity Monitor"
    echo "       for optimal unified memory performance with large models"
fi

# Check Metal framework availability
if [ -d "/System/Library/Frameworks/Metal.framework" ]; then
    echo "[ok]  Metal framework available"
else
    echo "[warning] Metal framework not found - Metal acceleration may not work"
fi

# CPU performance mode (favor efficiency for sustained workloads)
echo "Configuring CPU performance mode..."
if ! pmset -g | grep -q "lowpowermode.*0"; then
    pmset -a lowpowermode 0
    echo "[set] CPU performance mode: normal (not low power)"
    CHANGED=1
fi

# Disable sudden termination for better inference stability
if ! launchctl_check "com.apple.sudden_termination_disabled"; then
    echo "[info] Consider disabling sudden termination for long-running inference"
    echo "       This can be done via Activity Monitor or application plist"
fi

echo ""
if [ "$CHANGED" -gt 0 ]; then
    echo "✅ System configuration updated. Changes take effect immediately."
    echo "   A reboot is recommended for optimal performance."
else
    echo "✅ System already optimally configured for Jenova."
fi

echo ""
echo "📋 Next steps:"
echo "   1. Ensure Metal is enabled in System Settings > Privacy & Security"
echo "   2. Monitor memory usage during inference with Activity Monitor"
echo "   3. Consider enabling 'Prevent automatic sleeping on power adapter'"
echo "      in System Settings > Energy Saver for long-running tasks"