#!/bin/sh

# jenova-setup: One-time system configuration for Jenova Cognitive Architecture
# Hardware: HP Laptop 15s-eq2xxx | AMD Ryzen 7 5700U | AMD Lucienne (Vega 8)
# Run with: sudo ./jenova-setup
#
# Configures:
#   - ZFS ARC tuning to free RAM for GPU UMA and model inference
#   - Swap paging optimization for standard NVMe (not Optane)
#   - AMD GPU (drm-kmod) driver verification
#
# Hardware context:
#   AMD Lucienne (Vega 8) is a UMA GPU — it shares system RAM.
#   With 15.28 GiB total RAM and 16 GiB ZFS swap, the kernel pages
#   inactive LLM weights through the Vega 8's shared memory pool.
#   Standard NVMe swap latency (~100us) is higher than Optane (~7us),
#   so aggressive swap paging is less effective — keep working set in RAM.

set -e

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (sudo ./jenova-setup)"
    exit 1
fi

echo "=== jenova-setup: configuring FreeBSD for Jenova CA ==="
echo "=== Hardware: HP 15s-eq2xxx | Ryzen 7 5700U | AMD Lucienne ==="
echo ""

CHANGED=0

# Helper: add to sysctl.conf if not already present, avoiding duplicates
sysctl_persist() {
    _line="$1"
    _key=$(echo "$_line" | cut -d= -f1)
    _esc_key=$(printf '%s' "$_key" | sed 's|[.[*^$/]|\\&|g')
    _tmp=$(mktemp)
    trap 'rm -f "$_tmp"' EXIT INT TERM
    # Remove all existing instances of this key and append the new value
    if [ -f /etc/sysctl.conf ]; then
        grep -vE "^${_esc_key}[[:space:]]*=" /etc/sysctl.conf > "$_tmp" || true
    fi
    echo "$_line" >> "$_tmp"
    [ -f /etc/sysctl.conf ] && cp -p /etc/sysctl.conf /etc/sysctl.conf.bak
    
    if [ -f /etc/sysctl.conf ]; then
        cp "$_tmp" /etc/sysctl.conf
    else
        install -m 644 "$_tmp" /etc/sysctl.conf
    fi
    trap - EXIT INT TERM
}

apply_sysctl() {
    _key="$1"
    _val="$2"
    _desc="$3"
    _current=$(sysctl -n "$_key" 2>/dev/null || echo "?")
    if [ "$_current" = "$_val" ]; then
        echo "[ok]  $_key=$_val ($_desc)"
    else
        echo "[fix] $_key: $_current -> $_val ($_desc)"
        sysctl "$_key=$_val"
        sysctl_persist "$_key=$_val"
        CHANGED=1
    fi
}

# =========================================================================
# 1. AMD GPU / DRM driver check
# =========================================================================
echo ""
echo "--- AMD GPU Driver Check ---"

if kldstat -q -m amdgpu 2>/dev/null; then
    echo "[ok]  amdgpu kernel module loaded"
elif kldstat -q -m radeonkms 2>/dev/null; then
    echo "[ok]  radeonkms kernel module loaded (legacy — amdgpu preferred for Lucienne)"
    echo "      Consider: pkg install drm-kmod && sysrc kld_list+=amdgpu"
else
    echo "[warn] No AMD GPU kernel module loaded"
    echo "      Install: pkg install drm-kmod gpu-firmware-amd-kmod"
    echo "      Enable:  sysrc kld_list+=amdgpu"
    echo "      Then reboot. Vulkan requires the DRM driver."
fi

# Check for RADV (Mesa Vulkan driver for AMD)
if command -v vulkaninfo >/dev/null 2>&1; then
    if vulkaninfo --summary 2>/dev/null | grep -qi "RADV\|radeon\|AMD"; then
        echo "[ok]  RADV Vulkan driver detected"
    else
        echo "[warn] RADV Vulkan driver not detected"
        echo "      Install: pkg install mesa-dri mesa-libs vulkan-loader"
    fi
else
    echo "[info] vulkaninfo not available — install: pkg install vulkan-tools"
fi

# =========================================================================
# 2. NVMe Swap Tuning (standard NVMe — not Optane)
# =========================================================================
echo ""
echo "--- NVMe Swap Tuning (Standard NVMe) ---"
echo "  Note: Standard NVMe has ~100us latency (vs ~7us for Optane)."
echo "  Swap paging is functional but slower — keep working set in RAM."

# Don't panic on OOM — let the pager work
apply_sysctl vm.panic_on_oom 0 "no kernel panic on OOM"

# Keep swap enabled and proactive
apply_sysctl vm.disable_swapspace_pageouts 0 "allow swap pageouts"

# Moderate pageout cycle — not as aggressive as Optane config
# because standard NVMe swap is slower
apply_sysctl vm.pageout_update_period 2 "moderate pageout cycle (standard NVMe)"

# Compute page targets from runtime page size
PAGE_SIZE=$(getconf PAGESIZE 2>/dev/null || echo 4096)
# Target: 2 GiB free, 2 GiB inactive (less aggressive than Optane config)
FREE_PAGES=$(( (2 * 1024 * 1024 * 1024) / PAGE_SIZE ))
INACTIVE_PAGES=$(( (2 * 1024 * 1024 * 1024) / PAGE_SIZE ))

apply_sysctl vm.v_free_target "$FREE_PAGES" "2 GiB free page target"
apply_sysctl vm.v_inactive_target "$INACTIVE_PAGES" "2 GiB inactive target"

# Moderate inactive scan — less aggressive since NVMe swap is slower
apply_sysctl vm.inact_scan_laundry_weight 15 "moderate inactive scan (standard NVMe)"
apply_sysctl vm.act_scan_laundry_weight 5 "moderate active scan"

# =========================================================================
# 3. ZFS ARC Tuning
# =========================================================================
echo ""
echo "--- ZFS ARC Tuning ---"
echo "  With 15.28 GiB RAM shared between CPU inference, UMA GPU, and ZFS:"
echo "  Cap ARC at 1.5 GiB to leave ~13 GiB for inference workloads."

# 1.5 GiB ARC max — slightly more than the dual-GPU config since
# this system relies more on CPU inference and benefits from cached reads
apply_sysctl vfs.zfs.arc_max 1610612736 "ZFS ARC max 1.5 GiB"

# =========================================================================
# 4. OOM Policy
# =========================================================================
echo ""
echo "--- OOM / Memory Policy ---"

if sysctl kern.racct.enable > /dev/null 2>&1; then
    _RACCT=$(sysctl -n kern.racct.enable 2>/dev/null || echo "0")
    if [ "$_RACCT" = "1" ]; then
        echo "[ok]  kern.racct.enable=1 (RCTL available for per-process memory limits)"
        echo "      To limit llama-server memory, add to /etc/rctl.conf:"
        echo "      process:llama-server:memoryuse:deny=12G"
    else
        echo "[info] kern.racct.enable=0 — RCTL not active."
        echo "      To enable: add kern.racct.enable=1 to /boot/loader.conf and reboot."
    fi
else
    echo "[info] RACCT/RCTL not compiled into kernel."
fi

apply_sysctl vm.pageout_oom_seq 8 "OOM kill after 8 failed pageout sequences"

# =========================================================================
# 5. AMD-specific: CPU frequency scaling
# =========================================================================
echo ""
echo "--- CPU Power Management ---"

if sysctl dev.cpufreq.0.freq >/dev/null 2>&1; then
    echo "[info] cpufreq available — for best inference performance:"
    echo "      sysctl dev.cpufreq.0.freq=\$(sysctl -n dev.cpufreq.0.freq_levels | cut -d/ -f1)"
    echo "      Or use powerd: sysrc powerd_enable=YES && service powerd start"
    echo "      powerd -a hiadaptive -b adaptive  (max perf on AC, balanced on battery)"
else
    echo "[info] cpufreq not available — CPU runs at fixed frequency"
fi

echo ""
if [ "$CHANGED" -eq 1 ]; then
    echo "Done. Sysctl changes applied and persisted."
    echo "Verify swap: swapinfo"
else
    echo "Nothing to change. System already configured."
fi
