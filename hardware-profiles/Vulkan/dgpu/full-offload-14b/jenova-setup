#!/bin/sh
# jenova-setup: Quick profile deployment for Vulkan Full Offload
# Symlinks this profile's jenova.conf to $JENOVA_ROOT/etc/jenova.conf

set -e

PROFILE_DIR="$(dirname "$(realpath "$0")")"
JENOVA_ROOT="$(dirname "$(dirname "$(dirname "$(dirname "$PROFILE_DIR")")")")"
PROFILE_CONF="$PROFILE_DIR/jenova.conf"
TARGET_CONF="$JENOVA_ROOT/etc/jenova.conf"

echo "Deploying Vulkan Full Offload profile..."

# Backup existing config if it exists and isn't a symlink
if [ -f "$TARGET_CONF" ] && [ ! -L "$TARGET_CONF" ]; then
    BACKUP="$TARGET_CONF.bak.$(date +%Y%m%d-%H%M%S)"
    echo "  Backing up: $BACKUP"
    mv "$TARGET_CONF" "$BACKUP"
fi

# Remove old symlink if it exists
if [ -L "$TARGET_CONF" ]; then
    rm "$TARGET_CONF"
fi

# Create symlink
ln -s "$PROFILE_CONF" "$TARGET_CONF"
echo "  Linked: $TARGET_CONF -> $PROFILE_CONF"
echo ""
echo "Profile activated: Vulkan Full Offload"
echo "Restart Jenova to apply: bin/jenova-ca restart"
