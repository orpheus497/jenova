#!/bin/sh
# jenova-setup: System tuning for FreeBSD Optane NVMe Swap + dual GPU profile

if [ "$(id -u)" != "0" ]; then
    echo "Error: Must be run as root"
    exit 1
fi

echo "Applying FreeBSD system tuning for Optane NVMe Swap and Iris Xe UMA..."

# Aggressively use swap, relying on the Optane NVMe's low latency and high endurance
sysctl vm.swap_enabled=1
sysctl vm.swap_idle_enabled=1
sysctl vm.swap_idle_threshold1=2
sysctl vm.swap_idle_threshold2=10

LOADER_CONF="/boot/loader.conf.local"

update_loader_conf() {
    _key="$1"
    _val="$2"
    if ! grep -q "^${_key}=${_val}" "$LOADER_CONF" 2>/dev/null; then
        _tmp=$(mktemp "${LOADER_CONF}.XXXXXX")
        if [ -f "$LOADER_CONF" ]; then
            grep -v "^${_key}=" "$LOADER_CONF" > "$_tmp" || true
        fi
        echo "${_key}=${_val}" >> "$_tmp"
        chmod 644 "$_tmp"
        mv "$_tmp" "$LOADER_CONF"
    fi
}

# Tune ZFS ARC to leave maximum RAM available for the LLM layers and UMA (Iris Xe)
# 16GB total RAM -> Cap ARC at 2GB
update_loader_conf "vfs.zfs.arc_max" "2147483648"
sysctl vfs.zfs.arc_max=2147483648 2>/dev/null || true

# Increase NVMe timeout for heavy swap pressure
update_loader_conf "hw.nvme.timeout" "30"

echo "System tuning applied. Reboot is recommended for loader.conf changes to take full effect."
