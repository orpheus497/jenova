#define NVIM_COMPAT_MAJOR @NVIM_COMPAT_MAJOR@
#define NVIM_COMPAT_MINOR @NVIM_COMPAT_MINOR@
#define NVIM_COMPAT_PATCH @NVIM_COMPAT_PATCH@

