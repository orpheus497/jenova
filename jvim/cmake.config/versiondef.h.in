#define JVIM_VERSION_MINOR @JVIM_VERSION_MINOR@
#define JVIM_VERSION_PATCH @JVIM_VERSION_PATCH@

#cmakedefine NVIM_VERSION_MEDIUM "@NVIM_VERSION_MEDIUM@"
