#!/bin/sh
# jenova.local.conf.example: Template for host-specific runtime overrides
#
# This file demonstrates how to override llama.cpp runtime settings for your
# specific hardware. Copy this to jenova.local.conf and customize the values.
#
# Generation:
#   - Auto-generated by bin/build-llama-jenova during initial build
#   - Can be manually created by copying this template
#
# Usage:
#   cp etc/jenova.local.conf.example etc/jenova.local.conf
#   # Edit jenova.local.conf with your hardware-specific values
#
# Note: jenova.local.conf is gitignored to prevent committing host-specific
# configuration. Always use this template as a reference.

# Path to built llama-server binary
LLAMA_SERVER="$JENOVA_ROOT/llama.cpp/build/bin/llama-server"

# CPU threads for inference (physical cores recommended)
# Default: auto-detected from hardware profile
THREADS="${JENOVA_THREADS:-}"

# CPU threads for batch processing (can exceed physical cores)
# Default: auto-detected, typically physical + 2
THREADS_BATCH="${JENOVA_THREADS_BATCH:-}"

# GPU layer offload for 7B models
# Options: "all" (full offload), or a number (partial offload, e.g., "18")
# Default: depends on GPU VRAM (auto-detected by build-llama-jenova)
NGL_AGENT="${JENOVA_NGL_AGENT:-}"

# Memory fit target (MiB) — safety margin for KV cache
# Recommended: 512-1024 for single GPU, 768 for dual-GPU
FIT_TARGET="${JENOVA_FITT:-}"

# KV cache quantization type
# Options: q8_0 (recommended), q4_0, f16
KV_CACHE_TYPE="${JENOVA_KV_TYPE:-q8_0}"

# GPU devices (Vulkan)
# Examples:
#   Single GPU:  DEVICES="Vulkan0"
#   Dual GPU:    DEVICES="Vulkan0,Vulkan1"
DEVICES="${JENOVA_DEVICES:-}"

# Tensor split ratios for multi-GPU (comma-separated weights)
# Example: "1.0,1.8" for dual-GPU with 4GB + 7GB
# Leave empty for single GPU
TENSOR_SPLIT="${JENOVA_TS:-}"

# --- Model path overrides ---
# By default, Jenova auto-discovers the first .gguf file in each model folder:
#   models/agent/   → main inference model
#   models/embed/   → embedding model for RAG
#   models/draft/   → drafter for speculative decoding
#
# Override any model path by setting these variables.
# JENOVA_MODEL overrides the agent model path.
# JENOVA_EMBED_MODEL overrides the embedding model path.
# JENOVA_DRAFT_MODEL overrides the draft model path (applied during jenova.conf sourcing).
# JENOVA_DRAFT_PATH is a jenova-ca-specific alias; it takes precedence over JENOVA_DRAFT_MODEL
#   at runtime and is the final value used to pass -md to llama-server.
#   For most users, setting JENOVA_DRAFT_MODEL is sufficient.
#
# JENOVA_MODEL="$JENOVA_ROOT/models/agent/MyCustomModel-Q5_K_M.gguf"
# JENOVA_EMBED_MODEL="$JENOVA_ROOT/models/embed/my-embed-model.gguf"
# JENOVA_DRAFT_MODEL="$JENOVA_ROOT/models/draft/my-draft-model.gguf"
# JENOVA_DRAFT_PATH="$JENOVA_ROOT/models/draft/my-draft-model.gguf"

# --- Backend-specific settings ---

# Vulkan: Allow system memory fallback under pressure
# Recommended: 1 (enabled)
GGML_VK_ALLOW_SYSMEM_FALLBACK="${GGML_VK_ALLOW_SYSMEM_FALLBACK:-1}"

# CUDA: Discrete Multi-Memory Virtual pool size (MiB)
# Recommended: 512-2048 depending on available VRAM
GGML_CUDA_DMMV_POOL_SIZE="${GGML_CUDA_DMMV_POOL_SIZE:-512}"
