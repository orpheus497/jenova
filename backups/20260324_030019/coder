#!/bin/sh

# Get the script directory for relative paths
SCRIPT_DIR=$(dirname "$(realpath "$0")")

# Paths to the llama-cli and the Qwen 2.5 Coder model
LLAMA_CLI="$SCRIPT_DIR/llama.cpp/build/bin/llama-cli"
MODEL_PATH="$SCRIPT_DIR/models/Qwen2.5-Coder-7B-Q4_K_M.gguf"

# System Prompt
SYSTEM_PROMPT="You are my coding assistant, we are using FreeBSD as our OS."

# Check if binaries exist
if [ ! -f "$LLAMA_CLI" ]; then
    echo "Error: llama-cli not found at $LLAMA_CLI"
    echo "Make sure you have built llama.cpp."
    exit 1
fi

# Check if model exists, if not, offer to download it
if [ ! -f "$MODEL_PATH" ]; then
    echo "Error: Model not found at $MODEL_PATH"
    echo "You can download it using:"
    echo "curl -L -o \"$MODEL_PATH\" https://huggingface.co/Qwen/Qwen2.5-Coder-7B-Instruct-GGUF/resolve/main/qwen2.5-coder-7b-instruct-q4_k_m.gguf"
    
    # Optional: ask the user if they want to download it now
    # For now, we'll just exit with a clear message.
    exit 1
fi

# Execute llama-cli with dual-GPU Vulkan offloading
# -sm layer: Split layers across GPUs for better performance on heterogeneous setups.
# -ts 1.5,1: Prioritize Dedicated GPU (Vulkan0) over Integrated (Vulkan1).
# -fitt 1024: Target ~90% VRAM utilization (leave 1024MB margin).
# -c 32768: High-quality 32k context for coding tasks.
# -ngl all: Fully offload model and KV to GPUs.
"$LLAMA_CLI" \
  -m "$MODEL_PATH" \
  -dev Vulkan0,Vulkan1 \
  -ngl all \
  -sm layer \
  -ts 1.5,1 \
  -fitt 1024 \
  -c 32768 \
  -b 2048 \
  -ub 512 \
  -sys "$SYSTEM_PROMPT" \
  -cnv \
  "$@"

