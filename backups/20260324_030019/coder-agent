#!/bin/sh

# coder-agent: Launch the agentic coding assistant
# Starts llama-server (if not already running), then connects the LuaJIT agent

SCRIPT_DIR=$(dirname "$(realpath "$0")")
HOST="${CODER_HOST:-127.0.0.1}"
PORT="${CODER_PORT:-8080}"
API_URL="http://${HOST}:${PORT}"

# Check if server is already running
if curl -s -o /dev/null -w '%{http_code}' "${API_URL}/health" 2>/dev/null | grep -q 200; then
    echo "Server already running at ${API_URL}"
else
    echo "Starting llama-server in background..."
    "$SCRIPT_DIR/coder-server" &
    SERVER_PID=$!

    # Wait for server to be ready
    printf "Waiting for server"
    for i in $(seq 1 120); do
        if curl -s -o /dev/null -w '%{http_code}' "${API_URL}/health" 2>/dev/null | grep -q 200; then
            echo " ready!"
            break
        fi

        # Liveness probe: check the server process is still running; fail fast if it exited
        if ! kill -0 "$SERVER_PID" 2>/dev/null; then
            echo "server died"
            kill "$SERVER_PID" 2>/dev/null
            exit 1
        fi

        printf "."
        sleep 1
        if [ $i -eq 120 ]; then
            echo " timeout!"
            kill "$SERVER_PID" 2>/dev/null
            exit 1
        fi
    done
fi

# Trap to clean up server on exit
cleanup() {
    if [ -n "$SERVER_PID" ]; then
        echo "Stopping server (PID $SERVER_PID)..."
        kill "$SERVER_PID" 2>/dev/null
        wait "$SERVER_PID" 2>/dev/null
    fi
}
trap cleanup EXIT INT TERM

# Run the LuaJIT agent
export CODER_API_URL="$API_URL"

# Start luajit as a child process so the EXIT trap can run cleanup
luajit "$SCRIPT_DIR/agent.lua" &
AGENT_PID=$!

# Wait for the agent to exit, capture status, then run cleanup explicitly
wait "$AGENT_PID"
AGENT_STATUS=$?

cleanup
exit "$AGENT_STATUS"
