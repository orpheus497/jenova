#!/bin/sh
# build-llama-hybrid: Build llama.cpp with both Vulkan and CUDA support.
#
# This is a convenience wrapper around bin/build-llama-jenova.
# It enables both backends for systems with multiple GPUs (e.g., NVIDIA + AMD/Intel)
# or for users who want the flexibility of switching backends at runtime.

set -e

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"

export JENOVA_BACKEND="hybrid"

echo "== Jenova Hybrid Build (Vulkan + CUDA) =="
exec "$SCRIPT_DIR/build-llama-jenova" "$@"
