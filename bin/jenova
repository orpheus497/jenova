#!/bin/sh

# jenova: Launch the Jenova Cognitive Architecture agent
# Starts jenova-ca (if not already running), then connects the LuaJIT agent

SCRIPT_DIR=$(dirname "$(realpath "$0")")

# Determine JENOVA_ROOT before loading config
if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
    export JENOVA_ROOT="$SCRIPT_DIR"
    . "$SCRIPT_DIR/etc/jenova.conf"
elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
    . "$SCRIPT_DIR/../etc/jenova.conf"
else
    echo "Error: etc/jenova.conf not found."
    exit 1
fi

# Separate HOST (bind address) from CONNECT_HOST (client connect address)
# HOST may be 0.0.0.0 (listen on all interfaces), but clients need a real IP
CONNECT_HOST="${JENOVA_CONNECT_HOST:-127.0.0.1}"
API_URL="http://${CONNECT_HOST}:${PORT}"
JENOVA_DIR="${JENOVA_STATE:-$SCRIPT_DIR/.jenova}"
if [ -n "$LOG_DIR" ]; then
    SERVER_LOG="$LOG_DIR/jenova-ca.log"
else
    SERVER_LOG="${JENOVA_DIR}/jenova-ca.log"
fi

# Ensure directories exist
mkdir -p "$JENOVA_DIR"
[ -n "$LOG_DIR" ] && mkdir -p "$LOG_DIR"
[ -n "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

# Health check — uses luajit with the FFI HTTP module (zero dependencies)
# Accepts HTTP 200 from the proxy /health endpoint as the success signal.
check_health() {
    if [ -f "$SCRIPT_DIR/lib/healthcheck.lua" ]; then
        luajit "$SCRIPT_DIR/lib/healthcheck.lua" "$CONNECT_HOST" "$PORT" 3 2>/dev/null
    elif [ -f "$SCRIPT_DIR/../lib/healthcheck.lua" ]; then
        luajit "$SCRIPT_DIR/../lib/healthcheck.lua" "$CONNECT_HOST" "$PORT" 3 2>/dev/null
    else
        return 1
    fi
}

STARTED_BY_THIS_INVOCATION=0
if check_health; then
    echo "Jenova CA already running at $API_URL"
else
    echo "Starting Jenova CA in background..."
    echo "Log: $SERVER_LOG"
    
    # Run the server script using --daemon mode (jenova-ca handles its own backgrounding)
    if [ -f "$SCRIPT_DIR/jenova-ca" ]; then
        if "$SCRIPT_DIR/jenova-ca" --daemon; then
            STARTED_BY_THIS_INVOCATION=1
        else
            echo "Error: jenova-ca failed to start" >&2
            exit 1
        fi
    elif [ -f "$SCRIPT_DIR/../jenova-ca" ]; then
        if "$SCRIPT_DIR/../jenova-ca" --daemon; then
            STARTED_BY_THIS_INVOCATION=1
        else
            echo "Error: jenova-ca failed to start" >&2
            exit 1
        fi
    else
        echo "Error: jenova-ca launcher not found."
        exit 1
    fi

    printf "Waiting for Jenova CA"
    for i in $(seq 1 120); do
        if check_health; then
            echo " ready!"
            break
        fi
        # Fast-fail: if all daemon PIDs are dead, don't keep waiting
        if [ -f "$PID_FILE" ]; then
            read _LP _PP _EP < "$PID_FILE" 2>/dev/null
            _ANY_ALIVE=false
            for _P in $_LP $_PP $_EP; do
                [ -n "$_P" ] && kill -0 "$_P" 2>/dev/null && _ANY_ALIVE=true
            done
            if ! $_ANY_ALIVE; then
                echo " failed! (all daemon processes died)"
                echo "Check log: $SERVER_LOG"
                exit 1
            fi
        fi
        printf "."
        sleep 1
        if [ "$i" -eq 120 ]; then
            echo " timeout!"
            echo "Check log: $SERVER_LOG"
            "$SCRIPT_DIR/jenova-ca" stop 2>/dev/null || "$SCRIPT_DIR/../jenova-ca" stop 2>/dev/null || true
            exit 1
        fi
    done
fi

export JENOVA_API_URL="$API_URL"
export JENOVA_ROOT="${JENOVA_ROOT}"

# Find agent.lua relative to script
if [ -f "$SCRIPT_DIR/lib/agent.lua" ]; then
    AGENT_PATH="$SCRIPT_DIR/lib/agent.lua"
elif [ -f "$SCRIPT_DIR/../lib/agent.lua" ]; then
    AGENT_PATH="$SCRIPT_DIR/../lib/agent.lua"
else
    echo "Error: agent.lua not found."
    exit 1
fi

# Run agent in foreground; on exit, stop the CA server only if we started it.
cleanup_agent() {
    if [ "$STARTED_BY_THIS_INVOCATION" = "1" ] && [ -f "$PID_FILE" ]; then
        if [ -f "$SCRIPT_DIR/jenova-ca" ]; then
            "$SCRIPT_DIR/jenova-ca" stop 2>/dev/null
        elif [ -f "$SCRIPT_DIR/../jenova-ca" ]; then
            "$SCRIPT_DIR/../jenova-ca" stop 2>/dev/null
        fi
    fi
}
trap cleanup_agent EXIT INT TERM

luajit "$AGENT_PATH"
AGENT_EXIT=$?

trap - EXIT INT TERM
cleanup_agent

exit $AGENT_EXIT
