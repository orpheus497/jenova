#!/bin/sh
# jenova-term: Launch a command in a modern terminal emulator.
# Support for foot, kitty, alacritty, ghostty, and GNOME Terminal.

CMD="$@"

if command -v foot >/dev/null 2>&1; then
    foot sh -c "$CMD"
elif command -v kitty >/dev/null 2>&1; then
    kitty sh -c "$CMD"
elif command -v alacritty >/dev/null 2>&1; then
    alacritty -e sh -c "$CMD"
elif command -v ghostty >/dev/null 2>&1; then
    ghostty -e sh -c "$CMD"
elif command -v gnome-terminal >/dev/null 2>&1; then
    gnome-terminal -- sh -c "$CMD"
elif command -v xterm >/dev/null 2>&1; then
    xterm -e sh -c "$CMD"
else
    # Fallback: execute directly in current terminal
    sh -c "$CMD"
fi
