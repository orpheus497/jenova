#!/bin/sh
# jenova-term: helper to launch a command in a terminal emulator

cmd="$*"

if [ "$(uname -s)" = "Darwin" ]; then
    exec osascript -e 'on run argv' -e 'tell application "Terminal" to do script (item 1 of argv)' -e 'end run' -- "$*"
fi

if command -v x-terminal-emulator >/dev/null 2>&1; then
    exec x-terminal-emulator -e "$@"
fi

for term in alacritty kitty wezterm gnome-terminal konsole xfce4-terminal mate-terminal lxterminal xterm; do
    if command -v "$term" >/dev/null 2>&1; then
        if [ "$term" = "gnome-terminal" ]; then
            exec "$term" -- "$@"
        elif [ "$term" = "wezterm" ]; then
            exec "$term" start -- "$@"
        else
            exec "$term" -e "$@"
        fi
    fi
done

echo "No terminal emulator found." >&2
exit 1
