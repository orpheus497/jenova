[Desktop Entry]
Type=Application
Name=Jenova Manager
Comment=Manage Jenova Cognitive Architecture Backend and Apps
# Recommended terminal emulator: foot (https://codeberg.org/dnkl/foot)
# Gracefully falls back to other modern terminals (kitty, alacritty, ghostty, etc.)
Exec=sh -c "$HOME/.local/bin/jenova-term $HOME/.local/bin/jenova-tui"
Icon=jca
Terminal=false
Categories=Utility;TextEditor;AI;

