#!/bin/sh

# jenova-ca: Launch llama-server + Intelligence Proxy
# FreeBSD 15 | GTX 1650 Ti 4GB | 16GB RAM | 27GB Optane NVMe swap
#
# CPU-predominant inference with partial NVIDIA offload.
# No mlock — mmap'd weights page through Optane swap.

set -e

SCRIPT_DIR=$(dirname "$(realpath "$0")")

if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
    . "$SCRIPT_DIR/etc/jenova.conf"
elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
    . "$SCRIPT_DIR/../etc/jenova.conf"
else
    echo "Error: etc/jenova.conf not found."
    exit 1
fi

mkdir -p "$JENOVA_STATE"
mkdir -p "$LOG_DIR"
mkdir -p "$CACHE_DIR"

# --- Model selection with NGL auto-tuning ---
MODEL_PATH="${JENOVA_MODEL:-$MODEL_7B}"
LLAMA_NGL="$NGL_7B"
if [ ! -f "$MODEL_PATH" ]; then
    echo "Primary model not found, falling back to 14B..."
    MODEL_PATH="$MODEL_14B"
    LLAMA_NGL="$NGL_14B"
    CTX_SIZE="${JENOVA_CTX:-8192}"
    NUM_SLOTS="${JENOVA_SLOTS:-1}"
fi

case "$MODEL_PATH" in
    *14B*|*14b*|*13B*|*13b*)
        LLAMA_NGL="${JENOVA_NGL:-$NGL_14B}"
        CTX_SIZE="${JENOVA_CTX:-8192}"
        NUM_SLOTS="${JENOVA_SLOTS:-1}"
        ;;
    *7B*|*7b*|*8B*|*8b*)
        LLAMA_NGL="${JENOVA_NGL:-$NGL_7B}"
        ;;
esac

if [ ! -f "$LLAMA_SERVER" ]; then
    echo "Error: llama-server not found at $LLAMA_SERVER"
    exit 1
fi
if [ ! -f "$MODEL_PATH" ]; then
    echo "Error: Model not found at $MODEL_PATH"
    exit 1
fi

DRAFT_PATH="${JENOVA_DRAFT_PATH:-$MODEL_DRAFT}"
DRAFT_ARGS=""
if [ -f "$DRAFT_PATH" ] && [ -n "$JENOVA_DRAFT" ]; then
    DRAFT_ARGS="-md $DRAFT_PATH -ngld all --draft-max 16 --draft-min 4 --draft-p-min 0.6"
fi

# --- Find proxy.lua ---
if [ -f "$SCRIPT_DIR/lib/proxy.lua" ]; then
    PROXY_SCRIPT="$SCRIPT_DIR/lib/proxy.lua"
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
elif [ -f "$SCRIPT_DIR/../lib/proxy.lua" ]; then
    PROXY_SCRIPT="$SCRIPT_DIR/../lib/proxy.lua"
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
else
    echo "Error: proxy.lua not found relative to $SCRIPT_DIR"
    exit 1
fi

export CODER_ROOT="$JENOVA_ROOT"
export JENOVA_LLAMA_URL="http://${HOST}:${LLAMA_PORT}"
export JENOVA_PROXY_PORT="$PORT"
export JENOVA_PROXY_HOST="$HOST"

# --- LD_LIBRARY_PATH for shared libs ---
LLAMA_LIB_DIR="$JENOVA_ROOT/llama.cpp/build/bin"
if [ -d "$LLAMA_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
fi

# --- Build device arguments ---
DEV_ARGS=""
if [ -n "$DEVICES" ]; then
    DEV_ARGS="-dev $DEVICES"
fi

# --- Control verbs ---
case "$1" in
    stop)
        if [ -f "$PID_FILE" ]; then
            read OLD_LLAMA_PID OLD_PROXY_PID < "$PID_FILE" 2>/dev/null || OLD_LLAMA_PID=$(cat "$PID_FILE")
            for P in $OLD_LLAMA_PID $OLD_PROXY_PID; do
                if [ -n "$P" ] && kill -0 "$P" 2>/dev/null; then
                    echo "Stopping PID $P..."
                    kill "$P" 2>/dev/null || true
                fi
            done
            rm -f "$PID_FILE"
            echo "Stopped."
        else
            echo "No PID file found at $PID_FILE"
        fi
        exit 0
        ;;
    status)
        if [ -f "$PID_FILE" ]; then
            read LLAMA_PID PROXY_PID < "$PID_FILE" 2>/dev/null || LLAMA_PID=$(cat "$PID_FILE")
            echo "PID file: $PID_FILE"
            for _N in "llama-server:$LLAMA_PID" "Proxy:$PROXY_PID"; do
                _LABEL=$(echo "$_N" | cut -d: -f1)
                _PID=$(echo "$_N" | cut -d: -f2)
                if [ -n "$_PID" ] && kill -0 "$_PID" 2>/dev/null; then
                    echo "$_LABEL running (PID $_PID)"
                else
                    echo "$_LABEL not running"
                fi
            done
        else
            echo "No PID file found at $PID_FILE"
        fi
        exit 0
        ;;
    restart)
        "$0" stop 2>/dev/null || true
        shift || true
        set -- "--daemon" "$@"
        ;;
esac

# --- Startup banner ---
echo "Starting Jenova CA..."
echo "  Model:     $MODEL_PATH"
echo "  Devices:   ${DEVICES:-CPU only}"
echo "  GPU Layers: $LLAMA_NGL"
echo "  Context:   $CTX_SIZE"
echo "  Slots:     $NUM_SLOTS"
echo "  MLock:     off (Optane NVMe swap backing)"
echo ""

# =====================================================================
# DAEMON MODE
# =====================================================================
if [ "$1" = "--daemon" ]; then
    shift
    if [ -f "$PID_FILE" ]; then
        read OLD_LLAMA_PID OLD_PROXY_PID < "$PID_FILE" 2>/dev/null || OLD_LLAMA_PID=$(cat "$PID_FILE")
        for _P in $OLD_LLAMA_PID $OLD_PROXY_PID; do
            if [ -n "$_P" ] && kill -0 "$_P" 2>/dev/null; then
                echo "Jenova CA already running (PID $_P)."
                exit 0
            fi
        done
        rm -f "$PID_FILE"
    fi

    LOG_FILE="${LOG_DIR}/jenova-ca.log"
    echo "Daemonizing... Logs at $LOG_FILE"

    "$LLAMA_SERVER" \
        -m "$MODEL_PATH" \
        $DEV_ARGS \
        -ngl "$LLAMA_NGL" \
        -c "$CTX_SIZE" \
        -b 2048 \
        -ub 256 \
        -np "$NUM_SLOTS" \
        -t "$THREADS" \
        -tb "$THREADS_BATCH" \
        -fa auto \
        -cb \
        --spm-infill \
        --offline \
        --host "$HOST" \
        --port "$LLAMA_PORT" \
        $DRAFT_ARGS \
        "$@" > "$LOG_FILE" 2>&1 &
    LLAMA_PID=$!

    sleep 3

    luajit "$PROXY_SCRIPT" >> "$LOG_FILE" 2>&1 &
    PROXY_PID=$!

    echo "$LLAMA_PID $PROXY_PID" > "$PID_FILE"
    echo "Started: llama-server=$LLAMA_PID proxy=$PROXY_PID"
    exit 0
fi

# =====================================================================
# FOREGROUND MODE
# =====================================================================
while [ "$1" = "--daemon" ]; do shift; done

"$LLAMA_SERVER" \
    -m "$MODEL_PATH" \
    $DEV_ARGS \
    -ngl "$LLAMA_NGL" \
    -c "$CTX_SIZE" \
    -b 2048 \
    -ub 256 \
    -np "$NUM_SLOTS" \
    -t "$THREADS" \
    -tb "$THREADS_BATCH" \
    -fa auto \
    -cb \
    --spm-infill \
    --offline \
    --host "$HOST" \
    --port "$LLAMA_PORT" \
    $DRAFT_ARGS \
    "$@" &
LLAMA_PID=$!

cleanup() {
    for P in $LLAMA_PID $PROXY_PID; do
        if [ -n "$P" ]; then
            echo "Stopping PID $P..."
            kill "$P" 2>/dev/null
            wait "$P" 2>/dev/null
        fi
    done
}
trap cleanup EXIT INT TERM

echo "Starting Jenova Intelligence Proxy on port $PORT..."
luajit "$PROXY_SCRIPT" &
PROXY_PID=$!

wait "$LLAMA_PID" "$PROXY_PID"
