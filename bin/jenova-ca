#!/bin/sh

# jenova-ca: Launch llama-server + Intelligence Proxy
# FreeBSD 15 | GTX 1650 Ti 4GB + Iris Xe UMA | 16GB RAM | 27GB Optane NVMe swap
#
# Dual-GPU inference: NVIDIA (discrete) + Intel Iris Xe (UMA) via Vulkan.
# No mlock — mmap'd weights page through Optane swap.
# Model: Qwen2.5-Coder-7B — all 28 layers fit on dual-GPU, 16k context, 2 slots.

set -e

SCRIPT_DIR=$(dirname "$(realpath "$0")")

if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
    . "$SCRIPT_DIR/etc/jenova.conf"
elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
    . "$SCRIPT_DIR/../etc/jenova.conf"
else
    echo "Error: etc/jenova.conf not found."
    exit 1
fi

mkdir -p "$JENOVA_STATE"
mkdir -p "$LOG_DIR"
mkdir -p "$CACHE_DIR"

# --- Model: 7B only ---
MODEL_PATH="${JENOVA_MODEL:-$MODEL_7B}"
LLAMA_NGL="${JENOVA_NGL:-$NGL_7B}"

if [ ! -f "$LLAMA_SERVER" ]; then
    echo "Error: llama-server not found at $LLAMA_SERVER"
    exit 1
fi
if [ ! -f "$MODEL_PATH" ]; then
    echo "Error: Model not found at $MODEL_PATH"
    exit 1
fi

DRAFT_PATH="${JENOVA_DRAFT_PATH:-$MODEL_DRAFT}"
DRAFT_ARGS=""
if [ -f "$DRAFT_PATH" ] && [ -n "$JENOVA_DRAFT" ]; then
    DRAFT_ARGS="-md $DRAFT_PATH -ngld all --draft-max 16 --draft-min 4 --draft-p-min 0.6"
fi

# --- Find proxy.lua ---
if [ -f "$SCRIPT_DIR/lib/proxy.lua" ]; then
    PROXY_SCRIPT="$SCRIPT_DIR/lib/proxy.lua"
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
elif [ -f "$SCRIPT_DIR/../lib/proxy.lua" ]; then
    PROXY_SCRIPT="$SCRIPT_DIR/../lib/proxy.lua"
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
else
    echo "Error: proxy.lua not found relative to $SCRIPT_DIR"
    exit 1
fi

export JENOVA_LLAMA_URL="http://${HOST}:${LLAMA_PORT}"
export JENOVA_PROXY_PORT="$PORT"
export JENOVA_PROXY_HOST="$HOST"
export JENOVA_CTX="$CTX_SIZE"

# --- LD_LIBRARY_PATH for shared libs ---
LLAMA_LIB_DIR="$JENOVA_ROOT/llama.cpp/build/bin"
if [ -d "$LLAMA_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
fi

# --- Build device arguments ---
DEV_ARGS=""
if [ -n "$DEVICES" ]; then
    DEV_ARGS="-dev $DEVICES"
fi

# --- Split mode + fit target (always on; tensor split only if dual-GPU) ---
SPLIT_ARGS="-sm layer -fitt $FIT_TARGET"
if [ -n "$TENSOR_SPLIT" ]; then
    SPLIT_ARGS="$SPLIT_ARGS -ts $TENSOR_SPLIT"
fi

# --- KV cache quantization (halves KV memory vs f16) ---
KV_ARGS=""
if [ -n "$KV_CACHE_TYPE" ]; then
    KV_ARGS="-ctk $KV_CACHE_TYPE -ctv $KV_CACHE_TYPE"
fi

# --- Control verbs ---
case "$1" in
    stop)
        if [ -f "$PID_FILE" ]; then
            read OLD_LLAMA_PID OLD_PROXY_PID OLD_EMBED_PID < "$PID_FILE" 2>/dev/null || OLD_LLAMA_PID=$(cat "$PID_FILE")
            for P in $OLD_LLAMA_PID $OLD_PROXY_PID $OLD_EMBED_PID; do
                if [ -n "$P" ] && kill -0 "$P" 2>/dev/null; then
                    echo "Stopping PID $P..."
                    kill "$P" 2>/dev/null || true
                fi
            done
            sleep 1
            for P in $OLD_LLAMA_PID $OLD_PROXY_PID $OLD_EMBED_PID; do
                if [ -n "$P" ] && kill -0 "$P" 2>/dev/null; then
                    echo "Force-killing PID $P..."
                    kill -9 "$P" 2>/dev/null || true
                fi
            done
            rm -f "$PID_FILE"
            rm -f "$JENOVA_STATE/llama-embed.pid"
            echo "Stopped."
        else
            echo "No PID file found at $PID_FILE"
        fi
        pkill -f "llama-server.*${LLAMA_EMBED_PORT}" 2>/dev/null || true
        pkill -f "llama-server.*${LLAMA_PORT}" 2>/dev/null || true
        exit 0
        ;;
    status)
        if [ -f "$PID_FILE" ]; then
            read LLAMA_PID PROXY_PID EMBED_PID < "$PID_FILE" 2>/dev/null || LLAMA_PID=$(cat "$PID_FILE")
            echo "PID file: $PID_FILE"
            for _N in "llama-server:$LLAMA_PID" "Proxy:$PROXY_PID" "Embed:$EMBED_PID"; do
                _LABEL=$(echo "$_N" | cut -d: -f1)
                _PID=$(echo "$_N" | cut -d: -f2)
                if [ -n "$_PID" ] && kill -0 "$_PID" 2>/dev/null; then
                    echo "$_LABEL running (PID $_PID)"
                else
                    echo "$_LABEL not running"
                fi
            done
        else
            echo "No PID file found at $PID_FILE"
        fi
        exit 0
        ;;
    restart)
        "$0" stop 2>/dev/null || true
        shift || true
        set -- "--daemon" "$@"
        ;;
esac

# --- Startup banner ---
echo "Starting Jenova CA..."
echo "  Model:     $MODEL_PATH"
echo "  Embed:     $MODEL_EMBED (CPU-only, Vulkan disabled)"
echo "  Devices:   ${DEVICES:-CPU only}"
echo "  GPU Layers: $LLAMA_NGL${TENSOR_SPLIT:+ (ts $TENSOR_SPLIT)}${FIT_TARGET:+ (fitt $FIT_TARGET)}"
echo "  Context:   $CTX_SIZE  Slots: $NUM_SLOTS  KV: ${KV_CACHE_TYPE:-f16}"
echo ""

# =====================================================================
# DAEMON MODE
# =====================================================================
if [ "$1" = "--daemon" ]; then
    shift
    if [ -f "$PID_FILE" ]; then
        read OLD_LLAMA_PID OLD_PROXY_PID OLD_EMBED_PID < "$PID_FILE" 2>/dev/null || OLD_LLAMA_PID=$(cat "$PID_FILE")
        for _P in $OLD_LLAMA_PID $OLD_PROXY_PID $OLD_EMBED_PID; do
            if [ -n "$_P" ] && kill -0 "$_P" 2>/dev/null; then
                echo "Jenova CA already running (PID $_P)."
                exit 0
            fi
        done
        rm -f "$PID_FILE"
    fi

    LOG_FILE="${LOG_DIR}/jenova-ca.log"
    EMBED_LOG="${LOG_DIR}/jenova-embed.log"
    echo "Daemonizing... Logs at $LOG_FILE"

    "$LLAMA_SERVER" \
        -m "$MODEL_PATH" \
        $DEV_ARGS \
        $SPLIT_ARGS \
        $KV_ARGS \
        -c "$CTX_SIZE" \
        -b 2048 \
        -ub 256 \
        -np "$NUM_SLOTS" \
        -t "$THREADS" \
        -tb "$THREADS_BATCH" \
        -fa auto \
        -cb \
        --spm-infill \
        --cache-prompt \
        --offline \
        --host "$HOST" \
        --port "$LLAMA_PORT" \
        $DRAFT_ARGS \
        "$@" > "$LOG_FILE" 2>&1 &
    LLAMA_PID=$!

    EMBED_PID=""
    if [ -f "$MODEL_EMBED" ]; then
        GGML_VULKAN_DISABLE=1 "$LLAMA_SERVER" \
            -m "$MODEL_EMBED" \
            --embedding \
            -ngl 0 \
            -c 4096 \
            -b 512 \
            -t "$THREADS" \
            --offline \
            --host "$HOST" \
            --port "$LLAMA_EMBED_PORT" \
            > "$EMBED_LOG" 2>&1 &
        EMBED_PID=$!
    else
        echo "Warning: embed model not found at $MODEL_EMBED — skipping embed server"
    fi

    sleep 3

    luajit "$PROXY_SCRIPT" >> "$LOG_FILE" 2>&1 &
    PROXY_PID=$!

    # Write pidfile — never write "0" as a placeholder PID
    printf '%s' "$LLAMA_PID $PROXY_PID${EMBED_PID:+ $EMBED_PID}" > "$PID_FILE"
    echo "" >> "$PID_FILE"
    echo "Started: llama-server=$LLAMA_PID proxy=$PROXY_PID embed=${EMBED_PID:-none}"
    exit 0
fi

# =====================================================================
# FOREGROUND MODE
# =====================================================================
while [ "$1" = "--daemon" ]; do shift; done

"$LLAMA_SERVER" \
    -m "$MODEL_PATH" \
    $DEV_ARGS \
    $SPLIT_ARGS \
    $KV_ARGS \
    -c "$CTX_SIZE" \
    -b 2048 \
    -ub 256 \
    -np "$NUM_SLOTS" \
    -t "$THREADS" \
    -tb "$THREADS_BATCH" \
    -fa auto \
    -cb \
    --spm-infill \
    --cache-prompt \
    --offline \
    --host "$HOST" \
    --port "$LLAMA_PORT" \
    $DRAFT_ARGS \
    "$@" &
LLAMA_PID=$!

EMBED_PID=""
if [ -f "$MODEL_EMBED" ]; then
    echo "Starting embedding server (CPU-only) on port $LLAMA_EMBED_PORT..."
    GGML_VULKAN_DISABLE=1 "$LLAMA_SERVER" \
        -m "$MODEL_EMBED" \
        --embedding \
        -ngl 0 \
        -c 4096 \
        -b 512 \
        -t "$THREADS" \
        --offline \
        --host "$HOST" \
        --port "$LLAMA_EMBED_PORT" \
        > "${LOG_DIR}/jenova-embed.log" 2>&1 &
    EMBED_PID=$!
else
    echo "Warning: embed model not found at $MODEL_EMBED — skipping embed server"
fi

cleanup() {
    echo "Cleaning up..."
    kill -- -$$ 2>/dev/null || true
    for P in $LLAMA_PID $PROXY_PID $EMBED_PID; do
        if [ -n "$P" ] && kill -0 "$P" 2>/dev/null; then
            kill "$P" 2>/dev/null
        fi
    done
    sleep 1
    for P in $LLAMA_PID $PROXY_PID $EMBED_PID; do
        if [ -n "$P" ] && kill -0 "$P" 2>/dev/null; then
            kill -9 "$P" 2>/dev/null
        fi
    done
    pkill -f "llama-server.*${LLAMA_EMBED_PORT}" 2>/dev/null || true
    pkill -f "llama-server.*${LLAMA_PORT}" 2>/dev/null || true
    rm -f "$PID_FILE"
}
trap cleanup EXIT INT TERM

echo "Starting Jenova Intelligence Proxy on port $PORT..."
luajit "$PROXY_SCRIPT" &
PROXY_PID=$!

# Write pidfile — never write "0" as a placeholder PID
printf '%s' "$LLAMA_PID $PROXY_PID${EMBED_PID:+ $EMBED_PID}" > "$PID_FILE"
echo "" >> "$PID_FILE"

wait $LLAMA_PID $PROXY_PID ${EMBED_PID:+$EMBED_PID}
