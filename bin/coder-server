#!/bin/sh

# coder-server: Launch llama-server for the coder agent
# Optimized for: FreeBSD 15 | i5-1135G7 | GTX 1650 Ti 4GB | Intel Xe ~7GB | 16GB RAM
#
# Usage:
#   ./bin/coder-server                        # default: Q4_K_M, 8192 ctx
#   CODER_MODEL=path/to/model ./bin/coder-server  # override model
#   CODER_DRAFT=1 ./bin/coder-server          # enable speculative decoding

SCRIPT_DIR=$(dirname "$(realpath "$0")")
. "$SCRIPT_DIR/../etc/coder.conf"

# Ensure runtime directories exist
mkdir -p "$LOG_DIR" "$CACHE_DIR"

# Raise mlock limit (FreeBSD: sysctl security.bsd.unprivileged_mlock=1 must be set)
ulimit -l unlimited 2>/dev/null || ulimit -l 8388608 2>/dev/null || true

if [ ! -f "$LLAMA_SERVER" ]; then
    echo "Error: llama-server not found at $LLAMA_SERVER"
    echo "Build: cd llama.cpp && cmake -B build -DGGML_VULKAN=ON && cmake --build build -j\$(sysctl -n hw.ncpu)"
    exit 1
fi

if [ ! -f "$MODEL_PATH" ]; then
    echo "Error: Model not found at $MODEL_PATH"
    exit 1
fi

echo "Starting llama-server (GTX 1650 Ti 4GB + Iris Xe)..."
echo "  Model:   $MODEL_PATH"
echo "  Context: $CTX_SIZE tokens"
echo "  Listen:  $HOST:$PORT"
echo "  GPU:     $DEVICES (split $TENSOR_SPLIT)"
echo "  KV:      f16 (required for JSON accuracy)"
echo "  Flash:   auto"

DRAFT_ARGS=""
if [ -f "$MODEL_DRAFT" ] && [ -n "$CODER_DRAFT" ]; then
    echo "  Draft:   $MODEL_DRAFT (speculative decoding)"
    DRAFT_ARGS="-md $MODEL_DRAFT -ngld all --draft-max 16 --draft-min 4 --draft-p-min 0.6"
else
    echo "  Draft:   disabled (set CODER_DRAFT=1 to enable)"
fi
echo ""

exec "$LLAMA_SERVER" \
    -m "$MODEL_PATH" \
    -dev "$DEVICES" \
    -sm layer \
    -ts "$TENSOR_SPLIT" \
    -ngl all \
    -c "$CTX_SIZE" \
    -b 2048 \
    -ub 256 \
    -np 1 \
    -t "$THREADS" \
    -tb "$THREADS_BATCH" \
    -fa auto \
    --mlock \
    -cb \
    --host "$HOST" \
    --port "$PORT" \
    $DRAFT_ARGS \
    "$@"
