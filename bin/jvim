#!/bin/sh

# jvim: Launch the jvim editor only (no backend lifecycle management).
# FreeBSD 15 | Jenova Cognitive Architecture
#
# jvim is the editor-only entry point.  It does NOT start or stop jenova-ca.
# Use  bin/jenova  to start the full environment (backend + jvim).
#
# Responsibilities:
#   - Resolve JENOVA_ROOT and load etc/jenova.conf.
#   - Export JENOVA_CONNECT_HOST, JENOVA_PORT, JENOVA_LLAMA_PORT,
#     JENOVA_LLAMA_EMBED_PORT, JENOVA_ROOT, and JENOVA_API_URL.
#   - If no backend is reachable on startup, set JENOVA_LAN_SCAN=1 so the
#     in-editor lan.lua plugin auto-scans the subnet for a running server.
#   - Set LD_LIBRARY_PATH so external/llama.cpp shared libraries are visible to any
#     child process spawned by the editor.
#   - Detect whether the resolved binary is the jvim fork or upstream Neovim.
#
# Usage: jvim [options] [nvim args...]
#   --remote [host]     Connect to remote Jenova CA: explicit host or LAN auto-discover
#   --remote-port <p>   Override proxy port for remote mode      (default 8080)
#   --llama-port <p>    Override llama-server port for remote    (default 8081)
#   --embed-port <p>    Override embedding-server port for remote (default 8082)
#   --no-backend        Suppress the "no backend" warning (backend is managed externally)
#   --check             Print resolved JENOVA_* environment and exit
#   -h | --help         Show this help and exit

# Determine JENOVA_ROOT before loading config
# We use realpath to validate the path and ensure a malicious symlink cannot
# redirect us to a file outside the Jenova checkout. Run unconditionally so both
# remote and local modes inherit the same defaults (model paths, custom ports, etc.).
_REAL_EXE=$(realpath "$0" 2>/dev/null || readlink -f "$0")
_BIN_DIR=$(dirname "$_REAL_EXE")

if [ -f "$_BIN_DIR/../etc/jenova.conf" ]; then
    export JENOVA_ROOT="$(cd "$_BIN_DIR/.." && pwd)"
elif [ -f "$_BIN_DIR/etc/jenova.conf" ]; then
    export JENOVA_ROOT="$(cd "$_BIN_DIR" && pwd)"
else
    # Fallback to current behavior if not in a standard layout
    SCRIPT_DIR=$(dirname "$(realpath "$0")")
    if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
        export JENOVA_ROOT="$SCRIPT_DIR"
    elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
        export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
    else
        echo "Error: etc/jenova.conf not found."
        exit 1
    fi
fi

# Scrub repository-specific variables to prevent environment leaks
unset JENOVA_DEV_REPO

# Load environment and resolve paths
. "$JENOVA_ROOT/lib/detect-env.sh"
. "$JENOVA_ROOT/lib/jenova-conf.sh"
# shellcheck disable=SC1091
. "$JENOVA_ROOT/etc/jenova.conf"

# --- Parse jvim-specific flags, then pass remaining args to nvim via "$@" ---
REMOTE_HOST=""
REMOTE_AUTO_DISCOVER=0
REMOTE_PROXY_PORT="8080"
REMOTE_LLAMA_PORT="8081"
REMOTE_EMBED_PORT="8082"
NO_BACKEND=0
CHECK_ONLY=0

# Require a non-option argument after a flag; exits on missing/invalid value.
require_arg() {
    if [ -z "$2" ] || [ "${2#--}" != "$2" ]; then
        echo "Error: $1 requires a value, not another option" >&2
        exit 1
    fi
}

# Consume only jvim flags; stop at first non-jvim argument (preserves "$@" for nvim)
while [ $# -gt 0 ]; do
    case "$1" in
        --remote)
            shift
            # Optional argument: if next token exists and is not a flag, it's the host
            if [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; then
                if [ -z "$1" ]; then
                    echo "Error: --remote received an empty hostname argument." >&2
                    exit 1
                fi
                REMOTE_HOST="$1"; shift
            else
                # No host given → LAN auto-discover
                REMOTE_AUTO_DISCOVER=1
            fi
            ;;
        --remote-port) shift; require_arg "--remote-port" "$1"; REMOTE_PROXY_PORT="$1"; shift ;;
        --llama-port)  shift; require_arg "--llama-port" "$1";  REMOTE_LLAMA_PORT="$1"; shift ;;
        --embed-port)  shift; require_arg "--embed-port" "$1";  REMOTE_EMBED_PORT="$1"; shift ;;
        --no-backend)  NO_BACKEND=1; shift ;;
        --check)       CHECK_ONLY=1; shift ;;
        -h|--help)
            sed -n '2,34p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) break ;;  # First non-jvim arg — rest is for nvim
    esac
done

# --- Resolve the editor binary and verify it is jvim (warn-only) ---
# Resolution order:
#   1. $JVIM_BIN               — explicit override
#   2. $JENOVA_ROOT/jvim/build/bin/jvim — in-tree jvim build (preferred)
#   3. $JENOVA_ROOT/bin/jvim-core — deployed jvim build
#   4. nvim on PATH            — fallback (may be upstream Neovim)
_INTREE_JVIM="$JENOVA_ROOT/jvim/build/bin/jvim"
if [ ! -x "$_INTREE_JVIM" ]; then
    _INTREE_JVIM="$JENOVA_ROOT/jvim/build/bin/nvim"
fi
# Deployment fallback: look for jvim-core in the same bin directory
if [ ! -x "$_INTREE_JVIM" ] && [ -x "$JENOVA_ROOT/bin/jvim-core" ]; then
    _INTREE_JVIM="$JENOVA_ROOT/bin/jvim-core"
fi

if [ -n "$JVIM_BIN" ]; then
    EDITOR_BIN="$JVIM_BIN"
elif [ -x "$_INTREE_JVIM" ]; then
    EDITOR_BIN="$_INTREE_JVIM"
else
    EDITOR_BIN="nvim"
fi

if ! command -v "$EDITOR_BIN" >/dev/null 2>&1 && [ ! -x "$EDITOR_BIN" ]; then
    echo "Error: editor binary '$EDITOR_BIN' not found." >&2
    if [ "$JENOVA_LAYOUT" = "source" ]; then
        echo "       Build the in-tree jvim with: make jvim" >&2
    else
        echo "       Installation is corrupt. Please re-run the installer." >&2
    fi
    exit 1
fi

# Probe version string once; cheap and avoids repeating the call later.
_EDITOR_VERSION_LINE=$("$EDITOR_BIN" --version 2>/dev/null | head -n 1)
case "$_EDITOR_VERSION_LINE" in
    *JVIM*)
        IS_JVIM=1
        ;;
    *)
        IS_JVIM=0
        if [ "${JENOVA_QUIET:-0}" != "1" ]; then
            echo "Warning: '$EDITOR_BIN' is not jvim — Jenova plugins will still load," >&2
            echo "         but jvim-specific behaviour is unavailable." >&2
            if [ "$JENOVA_LAYOUT" = "source" ]; then
                echo "         Build the in-tree jvim: make jvim" >&2
            fi
        fi
        ;;
esac

# --- Helpers ---
# Build an http://host:port URL, bracketing IPv6 literals as required by RFC 3986.
build_http_url() {
    _h="$1"; _p="$2"
    case "$_h" in
        *:*) printf 'http://[%s]:%s' "$_h" "$_p" ;;
        *)   printf 'http://%s:%s'   "$_h" "$_p" ;;
    esac
}

# Print resolved JENOVA_* environment for --check
print_check_env() {
    echo "JENOVA_ROOT=$JENOVA_ROOT"
    echo "JENOVA_LAYOUT=$JENOVA_LAYOUT"
    echo "JENOVA_CONNECT_HOST=$JENOVA_CONNECT_HOST"
    echo "JENOVA_PORT=$JENOVA_PORT"
    echo "JENOVA_LLAMA_PORT=$JENOVA_LLAMA_PORT"
    echo "JENOVA_LLAMA_EMBED_PORT=$JENOVA_LLAMA_EMBED_PORT"
    echo "JENOVA_API_URL=$JENOVA_API_URL"
    echo "JENOVA_LAN_MODE=${JENOVA_LAN_MODE:-0}"
    echo "EDITOR_BIN=$EDITOR_BIN  ($_EDITOR_VERSION_LINE)"
    echo "IS_JVIM=$IS_JVIM"
}

# Point Neovim at the deployed jvim config (~/.config/jvim) and resolved runtime.
# XDG_CONFIG_HOME is intentionally left at its default so Neovim resolves
# NVIM_APPNAME="jvim" to ~/.config/jvim (deployed by install.sh / scripts/update.sh).
export XDG_DATA_HOME="${JENOVA_HOME}/share"
export NVIM_APPNAME="jvim"
export VIMRUNTIME="$VIMRUNTIME"

# --- Remote/LAN client mode: skip backend start, just export env and launch editor ---
# Two sub-modes:
#   jvim --remote <host>  — explicit host, connect and health-check immediately
#   jvim --remote         — LAN auto-discover: set JENOVA_LAN_MODE=1 and let the
#                           Lua plugin (jenova/lan.lua) scan the subnet for a
#                           running Jenova CA, then set JENOVA_CONNECT_HOST.
if [ -n "$REMOTE_HOST" ] || [ "$REMOTE_AUTO_DISCOVER" = "1" ]; then
    export JENOVA_PORT="$REMOTE_PROXY_PORT"
    export JENOVA_LLAMA_PORT="$REMOTE_LLAMA_PORT"
    export JENOVA_LLAMA_EMBED_PORT="$REMOTE_EMBED_PORT"
    export JENOVA_LAN_MODE="1"

    if [ -d "$LLAMA_LIB_DIR" ]; then
        export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
    fi

    if [ -n "$REMOTE_HOST" ]; then
        # Explicit host mode
        export JENOVA_CONNECT_HOST="$REMOTE_HOST"
        export JENOVA_API_URL="$(build_http_url "$REMOTE_HOST" "$REMOTE_PROXY_PORT")"
        echo "Jenova LAN client mode: connecting to $REMOTE_HOST:$REMOTE_PROXY_PORT"

        # Quick health check on the remote
        if command -v curl >/dev/null 2>&1; then
            _remote_url="$(build_http_url "$REMOTE_HOST" "$REMOTE_PROXY_PORT")/health"
            if curl -sf --max-time 3 --connect-timeout 2 "$_remote_url" >/dev/null 2>&1; then
                echo "Remote Jenova CA is healthy"
            else
                echo "Warning: Remote Jenova CA at $REMOTE_HOST:$REMOTE_PROXY_PORT is not responding" >&2
                echo "" >&2
                echo "Troubleshooting:" >&2
                echo "  1. Is jenova-ca running on $REMOTE_HOST?  (ssh $REMOTE_HOST bin/jenova-ca status)" >&2
                echo "  2. Is it bound to 0.0.0.0?  (JENOVA_HOST=0.0.0.0 in etc/jenova.conf on the server)" >&2
                echo "     Services bound to 127.0.0.1 reject LAN connections." >&2
                echo "  3. Firewall blocking port $REMOTE_PROXY_PORT?" >&2
                echo "" >&2
                echo "Editor will launch anyway — monitor will retry automatically" >&2
            fi
        fi
    else
        # Auto-discover mode: let the Lua plugin (jenova/lan.lua) scan the subnet
        echo "Jenova LAN auto-discover mode: scanning subnet for Jenova CA..."
        echo "The editor will connect automatically when a server is found."
    fi

    if [ "$CHECK_ONLY" = "1" ]; then
        print_check_env
        exit 0
    fi

    exec "$EDITOR_BIN" "$@"
fi

# Separate HOST (bind address) from CONNECT_HOST (client connect address).
CONNECT_HOST="${JENOVA_CONNECT_HOST:-127.0.0.1}"
API_URL="$(build_http_url "$CONNECT_HOST" "$PORT")"

# Ensure state dir exists for plugins that may write there
mkdir -p "$JENOVA_STATE"
mkdir -p "${XDG_DATA_HOME}"
[ -n "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

# Export environment for the jvim editor and Jenova plugins.
# llama.lua, chat.lua, jenova/monitor.lua, jenova/health.lua all read these.
# Keep this list in sync with runtime/doc/jvim.txt in the jvim repo.
export JENOVA_CONNECT_HOST="$CONNECT_HOST"
export JENOVA_PORT="$PORT"
export JENOVA_LLAMA_PORT="$LLAMA_PORT"
export JENOVA_LLAMA_EMBED_PORT="${LLAMA_EMBED_PORT:-8082}"
export JENOVA_ROOT="${JENOVA_ROOT}"
export JENOVA_API_URL="$API_URL"

if [ -d "$LLAMA_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
fi

# --- --check: dump resolved environment and exit ---
if [ "$CHECK_ONLY" = "1" ]; then
    print_check_env
    exit 0
fi

# --- Health check via curl ---
check_health() {
    if command -v curl >/dev/null 2>&1; then
        curl -sf --max-time 3 --connect-timeout 2 \
             "$(build_http_url "$CONNECT_HOST" "$PORT")/v1/health" >/dev/null 2>&1
    else
        return 1
    fi
}

# --- Check backend availability; set LAN_SCAN if none reachable ---
if [ "$NO_BACKEND" = "1" ]; then
    # Caller (bin/jenova) manages the backend — just report status quietly.
    if ! check_health && [ "${JENOVA_QUIET:-0}" != "1" ]; then
        echo "Note: backend not reachable at $API_URL (managed externally)" >&2
    fi
else
    if check_health; then
        if [ "${JENOVA_QUIET:-0}" != "1" ]; then
            echo "Jenova CA is ready at $API_URL"
        fi
    else
        # No local backend found — enable LAN scan so the Lua plugin
        # (jenova/lan.lua) discovers one on the subnet at startup.
        export JENOVA_LAN_SCAN=1
        if [ "${JENOVA_QUIET:-0}" != "1" ]; then
            echo "No local Jenova CA found — LAN scan enabled." >&2
            echo "Start a local backend with: jenova --daemon-only" >&2
        fi
    fi
fi

# --- Launch the editor ---
exec "$EDITOR_BIN" "$@"
