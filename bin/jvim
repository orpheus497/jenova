#!/bin/sh

# jvim: Launch the jvim editor (Neovim fork) with Jenova CA backend lifecycle.
# FreeBSD 15 | Jenova Cognitive Architecture
#
# This is the canonical entry point that interlinks the jvim editor frontend
# (orpheus497/jvim) with the Jenova cognitive backend (orpheus497/jenova).
#
# Responsibilities:
#   - Resolve JENOVA_ROOT and load etc/jenova.conf so client and backend share
#     the same host/port/model configuration.
#   - Export JENOVA_CONNECT_HOST, JENOVA_PORT, JENOVA_LLAMA_PORT,
#     JENOVA_LLAMA_EMBED_PORT, JENOVA_ROOT, and JENOVA_API_URL so that the
#     Jenova nvim plugins (llama.lua, gp.lua, jenova/monitor.lua,
#     jenova/health.lua) read the correct endpoints at startup.
#   - Set LD_LIBRARY_PATH so llama.cpp shared libraries are visible to any
#     child process spawned by the editor (e.g. headless Lazy installs).
#   - Start jenova-ca on demand and stop it on exit only when this invocation
#     started it (so concurrent jvim sessions do not race the daemon).
#   - Detect whether the resolved `nvim` binary is the jvim fork or upstream
#     Neovim, and warn (without failing) when running on upstream — the
#     plugins still work but jvim-specific behaviour will not be present.
#
# Usage: jvim [options] [nvim args...]
#   --remote <host>     Connect to a remote Jenova CA on the LAN (client mode)
#   --remote-port <p>   Override proxy port for remote mode      (default 8080)
#   --llama-port <p>    Override llama-server port for remote    (default 8081)
#   --embed-port <p>    Override embedding-server port for remote (default 8082)
#   --no-backend        Skip starting jenova-ca even in local mode
#                       (the editor still loads with Jenova env vars exported)
#   --check             Print resolved JENOVA_* environment and exit
#   -h | --help         Show this help and exit

SCRIPT_DIR=$(dirname "$(realpath "$0")")

# --- Parse jvim-specific flags, then pass remaining args to nvim via "$@" ---
REMOTE_HOST=""
REMOTE_PROXY_PORT="8080"
REMOTE_LLAMA_PORT="8081"
REMOTE_EMBED_PORT="8082"
NO_BACKEND=0
CHECK_ONLY=0

# Require a non-option argument after a flag; exits on missing/invalid value.
require_arg() {
    if [ -z "$2" ] || [ "${2#--}" != "$2" ]; then
        echo "Error: $1 requires a value, not another option" >&2
        exit 1
    fi
}

# Consume only jvim flags; stop at first non-jvim argument (preserves "$@" for nvim)
while [ $# -gt 0 ]; do
    case "$1" in
        --remote)      shift; require_arg "--remote" "$1";      REMOTE_HOST="$1";       shift ;;
        --remote-port) shift; require_arg "--remote-port" "$1"; REMOTE_PROXY_PORT="$1"; shift ;;
        --llama-port)  shift; require_arg "--llama-port" "$1";  REMOTE_LLAMA_PORT="$1"; shift ;;
        --embed-port)  shift; require_arg "--embed-port" "$1";  REMOTE_EMBED_PORT="$1"; shift ;;
        --no-backend)  NO_BACKEND=1; shift ;;
        --check)       CHECK_ONLY=1; shift ;;
        -h|--help)
            sed -n '2,32p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) break ;;  # First non-jvim arg — rest is for nvim
    esac
done

# --- Resolve the editor binary and verify it is jvim (warn-only) ---
# Allows JVIM_BIN override so the wrapper can drive a non-PATH build.
EDITOR_BIN="${JVIM_BIN:-nvim}"
if ! command -v "$EDITOR_BIN" >/dev/null 2>&1; then
    echo "Error: editor binary '$EDITOR_BIN' not found in PATH." >&2
    echo "       Install jvim from https://github.com/orpheus497/jvim or set JVIM_BIN." >&2
    exit 1
fi

# Probe version string once; cheap and avoids repeating the call later.
_EDITOR_VERSION_LINE=$("$EDITOR_BIN" --version 2>/dev/null | head -n 1)
case "$_EDITOR_VERSION_LINE" in
    *JVIM*)
        IS_JVIM=1
        ;;
    *)
        IS_JVIM=0
        if [ "${JENOVA_QUIET:-0}" != "1" ]; then
            echo "Warning: '$EDITOR_BIN' is not jvim — Jenova plugins will still load," >&2
            echo "         but jvim-specific behaviour is unavailable." >&2
            echo "         Install jvim: https://github.com/orpheus497/jvim" >&2
        fi
        ;;
esac

# --- Remote/LAN client mode: skip backend start, just export env and launch nvim ---
if [ -n "$REMOTE_HOST" ]; then
    export JENOVA_CONNECT_HOST="$REMOTE_HOST"
    export JENOVA_PORT="$REMOTE_PROXY_PORT"
    export JENOVA_LLAMA_PORT="$REMOTE_LLAMA_PORT"
    export JENOVA_LLAMA_EMBED_PORT="$REMOTE_EMBED_PORT"
    export JENOVA_API_URL="http://${REMOTE_HOST}:${REMOTE_PROXY_PORT}"
    export JENOVA_LAN_MODE="1"

    if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
        export JENOVA_ROOT="$SCRIPT_DIR"
    elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
        export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
    fi

    LLAMA_LIB_DIR="${JENOVA_ROOT:+$JENOVA_ROOT/llama.cpp/build/bin}"
    if [ -n "$LLAMA_LIB_DIR" ] && [ -d "$LLAMA_LIB_DIR" ]; then
        export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
    fi

    echo "Jenova LAN client mode: connecting to $REMOTE_HOST:$REMOTE_PROXY_PORT"

    # Quick health check on the remote
    _remote_healthy=false
    if command -v curl >/dev/null 2>&1; then
        _remote_url="http://${REMOTE_HOST}:${REMOTE_PROXY_PORT}/health"
        if echo "$REMOTE_HOST" | grep -q ":"; then _remote_url="http://[${REMOTE_HOST}]:${REMOTE_PROXY_PORT}/health"; fi
        if curl -sf --max-time 3 --connect-timeout 2 "$_remote_url" >/dev/null 2>&1; then
            echo "Remote Jenova CA is healthy"
            _remote_healthy=true
        else
            echo "Warning: Remote Jenova CA at $REMOTE_HOST:$REMOTE_PROXY_PORT is not responding" >&2
            echo "" >&2
            echo "Troubleshooting:" >&2
            echo "  1. Is jenova-ca running on $REMOTE_HOST?  (ssh $REMOTE_HOST bin/jenova-ca status)" >&2
            echo "  2. Is it bound to 0.0.0.0?  (JENOVA_HOST=0.0.0.0 in etc/jenova.conf on the server)" >&2
            echo "     Services bound to 127.0.0.1 reject LAN connections." >&2
            echo "  3. Firewall blocking port $REMOTE_PROXY_PORT?" >&2
            echo "" >&2
            echo "Neovim will launch anyway — monitor will retry automatically" >&2
        fi
    fi

    if [ "$CHECK_ONLY" = "1" ]; then
        echo "JENOVA_ROOT=$JENOVA_ROOT"
        echo "JENOVA_CONNECT_HOST=$JENOVA_CONNECT_HOST"
        echo "JENOVA_PORT=$JENOVA_PORT"
        echo "JENOVA_LLAMA_PORT=$JENOVA_LLAMA_PORT"
        echo "JENOVA_LLAMA_EMBED_PORT=$JENOVA_LLAMA_EMBED_PORT"
        echo "JENOVA_API_URL=$JENOVA_API_URL"
        echo "JENOVA_LAN_MODE=$JENOVA_LAN_MODE"
        echo "EDITOR_BIN=$EDITOR_BIN  ($_EDITOR_VERSION_LINE)"
        exit 0
    fi

    exec "$EDITOR_BIN" "$@"
fi

# Determine JENOVA_ROOT before loading config
if [ -f "$SCRIPT_DIR/etc/jenova.conf" ]; then
    export JENOVA_ROOT="$SCRIPT_DIR"
    . "$SCRIPT_DIR/etc/jenova.conf"
elif [ -f "$SCRIPT_DIR/../etc/jenova.conf" ]; then
    export JENOVA_ROOT="$(dirname "$SCRIPT_DIR")"
    . "$SCRIPT_DIR/../etc/jenova.conf"
else
    echo "Error: etc/jenova.conf not found." >&2
    exit 1
fi

# Separate HOST (bind address) from CONNECT_HOST (client connect address).
# HOST may be 0.0.0.0 (listen on all interfaces), but clients need a real IP.
CONNECT_HOST="${JENOVA_CONNECT_HOST:-127.0.0.1}"
API_URL="http://${CONNECT_HOST}:${PORT}"

JENOVA_DIR="${JENOVA_STATE:-$JENOVA_ROOT/.jenova}"
PID_FILE="$JENOVA_DIR/jenova-ca.pid"
if [ -n "$LOG_DIR" ]; then
    SERVER_LOG="$LOG_DIR/jenova-ca.log"
else
    SERVER_LOG="${JENOVA_DIR}/jenova-ca.log"
fi

# Ensure runtime directories exist
mkdir -p "$JENOVA_DIR"
[ -n "$LOG_DIR" ]   && mkdir -p "$LOG_DIR"
[ -n "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

# Export environment for the jvim editor and Jenova plugins.
# llama.lua, gp.lua, jenova/monitor.lua, jenova/health.lua all read these.
# Keep this list in sync with runtime/doc/jvim.txt in the jvim repo.
export JENOVA_CONNECT_HOST="$CONNECT_HOST"
export JENOVA_PORT="$PORT"
export JENOVA_LLAMA_PORT="$LLAMA_PORT"
export JENOVA_LLAMA_EMBED_PORT="${LLAMA_EMBED_PORT:-8082}"
export JENOVA_ROOT="${JENOVA_ROOT}"
export JENOVA_API_URL="$API_URL"

# Set LD_LIBRARY_PATH so llama.cpp shared libraries are found by llama-server
# even when Neovim's child processes inherit the environment.
LLAMA_LIB_DIR="$JENOVA_ROOT/llama.cpp/build/bin"
if [ -d "$LLAMA_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="$LLAMA_LIB_DIR${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
fi

# --- --check: dump resolved environment and exit ---
if [ "$CHECK_ONLY" = "1" ]; then
    echo "JENOVA_ROOT=$JENOVA_ROOT"
    echo "JENOVA_CONNECT_HOST=$JENOVA_CONNECT_HOST"
    echo "JENOVA_PORT=$JENOVA_PORT"
    echo "JENOVA_LLAMA_PORT=$JENOVA_LLAMA_PORT"
    echo "JENOVA_LLAMA_EMBED_PORT=$JENOVA_LLAMA_EMBED_PORT"
    echo "JENOVA_API_URL=$JENOVA_API_URL"
    echo "EDITOR_BIN=$EDITOR_BIN  ($_EDITOR_VERSION_LINE)"
    echo "IS_JVIM=$IS_JVIM"
    exit 0
fi

# --- Health check ---
# Uses LuaJIT + FFI HTTP (zero system dependencies; no curl required).
check_health() {
    if [ -f "$SCRIPT_DIR/../lib/healthcheck.lua" ]; then
        luajit "$SCRIPT_DIR/../lib/healthcheck.lua" "$CONNECT_HOST" "$PORT" 3 2>/dev/null
    elif [ -f "$SCRIPT_DIR/lib/healthcheck.lua" ]; then
        luajit "$SCRIPT_DIR/lib/healthcheck.lua" "$CONNECT_HOST" "$PORT" 3 2>/dev/null
    else
        return 1
    fi
}

# --- Locate jenova-ca ---
find_jenova_ca() {
    if [ -f "$SCRIPT_DIR/jenova-ca" ]; then
        echo "$SCRIPT_DIR/jenova-ca"
    elif [ -f "$SCRIPT_DIR/../bin/jenova-ca" ]; then
        echo "$SCRIPT_DIR/../bin/jenova-ca"
    else
        echo ""
    fi
}

JENOVA_CA=$(find_jenova_ca)
if [ -z "$JENOVA_CA" ]; then
    echo "Error: jenova-ca not found." >&2
    exit 1
fi

# --- Start backend if not already running ---
STARTED_BY_THIS_INVOCATION=0
if [ "$NO_BACKEND" = "1" ]; then
    if check_health; then
        echo "Jenova CA already running at $API_URL  (--no-backend: not touching it)"
    else
        echo "Warning: --no-backend set and Jenova CA is not running." >&2
        echo "         Plugins will fail to connect until you start it manually." >&2
    fi
elif check_health; then
    echo "Jenova CA already running at $API_URL"
else
    echo "Starting Jenova CA in background..."
    echo "Log: $SERVER_LOG"

    if "$JENOVA_CA" --daemon; then
        STARTED_BY_THIS_INVOCATION=1
    else
        echo "Error: jenova-ca failed to start" >&2
        exit 1
    fi

    # Wait for proxy to become ready (fast-fail on dead PIDs)
    printf "Waiting for Jenova CA"
    for i in $(seq 1 120); do
        if check_health; then
            echo " ready!"
            break
        fi
        # Fast-fail: if all daemon PIDs are dead, stop waiting
        if [ -f "$PID_FILE" ]; then
            read _LP _PP _EP < "$PID_FILE" 2>/dev/null || true
            _ANY_ALIVE=false
            for _P in $_LP $_PP $_EP; do
                [ -n "$_P" ] && kill -0 "$_P" 2>/dev/null && _ANY_ALIVE=true
            done
            if ! $_ANY_ALIVE; then
                echo " failed! (all daemon processes died)"
                echo "Check log: $SERVER_LOG"
                exit 1
            fi
        fi
        printf "."
        sleep 1
        if [ "$i" -eq 120 ]; then
            echo " timeout!"
            echo "Check log: $SERVER_LOG"
            exit 1
        fi
    done
fi

# --- Cleanup: stop backend on exit only if jvim started it ---
cleanup_jvim() {
    if [ "$STARTED_BY_THIS_INVOCATION" = "1" ] && [ -f "$PID_FILE" ]; then
        echo "Stopping Jenova CA..."
        "$JENOVA_CA" stop 2>/dev/null || true
    fi
}
trap cleanup_jvim EXIT INT TERM

# --- Launch the editor ---
# exec replaces this shell process with the editor; the EXIT trap fires when it exits.
exec "$EDITOR_BIN" "$@"
