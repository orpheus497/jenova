#!/bin/sh

# coder: Launch the agentic coding assistant
# Starts llama-server (if not already running), then connects the LuaJIT agent

SCRIPT_DIR=$(dirname "$(realpath "$0")")

# Load configuration
if [ -f "$SCRIPT_DIR/etc/coder.conf" ]; then
    . "$SCRIPT_DIR/etc/coder.conf"
elif [ -f "$SCRIPT_DIR/../etc/coder.conf" ]; then
    . "$SCRIPT_DIR/../etc/coder.conf"
else
    echo "Error: etc/coder.conf not found."
    exit 1
fi

API_URL="http://${HOST}:${PORT}"
CODER_DIR="${CODER_STATE:-$SCRIPT_DIR/.coder}"
SERVER_LOG="${LOG_DIR:-$CODER_DIR}/server.log"

# Ensure directories exist
mkdir -p "$CODER_DIR"
[ -n "$LOG_DIR" ] && mkdir -p "$LOG_DIR"
[ -n "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

# Health check — uses luajit with the FFI HTTP module (zero dependencies)
# Accepts 200, 404, 502, 503 as success codes for the launcher check
check_health() {
    luajit -e "
        local script_dir = [[$SCRIPT_DIR]]
        if script_dir:match('bin$') then script_dir = script_dir .. '/..' end
        package.path=script_dir .. '/lib/?.lua;' .. package.path
        local http=require('http')
        local c=http.get('http://${HOST}:${PORT}/health',3)
        -- Accept 200, 404, 502, 503
        local ok = (c==200 or c==404 or c==502 or c==503)
        os.exit(ok and 0 or 1)
    " 2>/dev/null
}

if check_health; then
    echo "Server already running at $API_URL"
else
    echo "Starting llama-server in background..."
    echo "Server log: $SERVER_LOG"
    
    # Run the server script (relative to this script's location)
    if [ -f "$SCRIPT_DIR/coder-server" ]; then
        "$SCRIPT_DIR/coder-server" > "$SERVER_LOG" 2>&1 &
    elif [ -f "$SCRIPT_DIR/../coder-server" ]; then
        "$SCRIPT_DIR/../coder-server" > "$SERVER_LOG" 2>&1 &
    else
        echo "Error: coder-server launcher not found."
        exit 1
    fi
    SERVER_PID=$!

    printf "Waiting for server"
    for i in $(seq 1 120); do
        if check_health; then
            echo " ready!"
            break
        fi
        printf "."
        sleep 1
        # Fix: quote the variable to prevent globbing (ShellCheck SC2086)
        if [ "$i" -eq 120 ]; then
            echo " timeout!"
            echo "Check server log: $SERVER_LOG"
            [ -n "$SERVER_PID" ] && kill "$SERVER_PID" 2>/dev/null
            exit 1
        fi
    done
fi

cleanup() {
    if [ -n "$SERVER_PID" ]; then
        echo "Stopping server (PID $SERVER_PID)..."
        kill "$SERVER_PID" 2>/dev/null
        wait "$SERVER_PID" 2>/dev/null
    fi
}
trap cleanup EXIT INT TERM

export CODER_API_URL="$API_URL"
export CODER_ROOT
# Find agent.lua relative to script
if [ -f "$SCRIPT_DIR/lib/agent.lua" ]; then
    AGENT_PATH="$SCRIPT_DIR/lib/agent.lua"
elif [ -f "$SCRIPT_DIR/../lib/agent.lua" ]; then
    AGENT_PATH="$SCRIPT_DIR/../lib/agent.lua"
else
    echo "Error: agent.lua not found."
    exit 1
fi

exec luajit "$AGENT_PATH"
