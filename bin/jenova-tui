#!/usr/bin/env bash
# jenova-tui: Simple TUI for managing Jenova Cognitive Architecture
# Provides status overview and controls for the jenova-ca backend.

set -e

SCRIPT_DIR=$(dirname "$(realpath "$0")")
JENOVA_ROOT=$(dirname "$SCRIPT_DIR")

# в”Җв”Җ Colors (Kanagawa & Royal Purple) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ESC=$'\e'
BG="${ESC}[48;2;31;31;40m"
FG="${ESC}[38;2;220;215;186m"
SEL_BG="${ESC}[48;2;45;79;103m"
GREEN="${ESC}[38;2;118;148;106m"
RED="${ESC}[38;2;195;64;67m"
BLUE="${ESC}[38;2;126;156;216m"
YELLOW="${ESC}[38;2;192;163;110m"
CYAN="${ESC}[38;2;106;149;137m"
PURPLE="${ESC}[38;2;120;81;169m"
BOLD="${ESC}[1m"
RESET="${ESC}[0m"
CLEAR="${ESC}[H${ESC}[2J${BG}${FG}"

# в”Җв”Җ Load Configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
JENOVA_CA="$SCRIPT_DIR/jenova-ca"
CONF_FILE="$JENOVA_ROOT/etc/jenova.conf"
LOCAL_CONF="$JENOVA_ROOT/etc/jenova.local.conf"

load_config() {
    if [ -f "$CONF_FILE" ]; then . "$CONF_FILE"; fi
    if [ -f "$LOCAL_CONF" ]; then . "$LOCAL_CONF"; fi
    
    # Defaults
    HOST="${HOST:-127.0.0.1}"
    PORT="${PORT:-8080}"
    JENOVA_LLAMA_URL="${JENOVA_LLAMA_URL:-http://127.0.0.1:8081}"
}

# в”Җв”Җ Status Logic в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Cache status for 2 seconds to avoid flickering and slow system calls
LAST_STATUS_CHECK=0
CACHED_STATUS=""
CACHED_STATUS_LBL=""

get_status() {
    local now
    now=$(date +%s)
    if [ $((now - LAST_STATUS_CHECK)) -ge 2 ]; then
        if "$JENOVA_CA" status | grep -q "running"; then
            CACHED_STATUS="${GREEN}ACTIVE${FG}"
            CACHED_STATUS_LBL="ACTIVE"
        else
            CACHED_STATUS="${RED}INACTIVE${FG}"
            CACHED_STATUS_LBL="INACTIVE"
        fi
        LAST_STATUS_CHECK=$now
    fi
    echo "$CACHED_STATUS"
}

get_status_lbl() {
    echo "$CACHED_STATUS_LBL"
}

get_mode() {
    if [ "$HOST" = "0.0.0.0" ] || [ "$HOST" = "::" ] || [ "$HOST" = "*" ]; then
        echo "${CYAN}LAN${FG} (Accessible from other devices)"
    else
        echo "${YELLOW}LOCAL${FG} (Accessible from this device only)"
    fi
}

# в”Җв”Җ Menu Actions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
update_config() {
    local key="$1"
    local value="$2"
    local tmp
    tmp=$(mktemp)
    
    # Touch file if it doesn't exist
    [ ! -f "$LOCAL_CONF" ] && touch "$LOCAL_CONF"
    
    # Use grep -v to remove existing key and append new one to avoid sed delimiter issues
    if [ -f "$LOCAL_CONF" ]; then
        grep -v "^$key=" "$LOCAL_CONF" > "$tmp" || true
    fi
    echo "$key=\"$value\"" >> "$tmp"
    
    # Atomic-ish write that preserves symlinks and attributes
    if cat "$tmp" > "$LOCAL_CONF"; then
        rm -f "$tmp"
        load_config
        return 0
    else
        rm -f "$tmp"
        return 1
    fi
}

is_valid_ip() {
    local ip="$1"
    local ip_regex='^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$'
    if [[ $ip =~ $ip_regex ]]; then
        return 0
    else
        return 1
    fi
}

start_backend() {
    printf "\n%sStarting Jenova CA backend...%s\n" "$GREEN" "$FG"
    "$JENOVA_CA" start
    LAST_STATUS_CHECK=0 # Invalidate cache
    sleep 1
}

stop_backend() {
    printf "\n%sStopping Jenova CA backend...%s\n" "$YELLOW" "$FG"
    "$JENOVA_CA" stop
    LAST_STATUS_CHECK=0 # Invalidate cache
    sleep 1
}

restart_backend() {
    printf "\n%sRestarting Jenova CA backend...%s\n" "$GREEN" "$FG"
    "$JENOVA_CA" stop 2>/dev/null || true
    sleep 1
    "$JENOVA_CA" start
    LAST_STATUS_CHECK=0 # Invalidate cache
    sleep 1
}

toggle_mode() {
    if [ "$HOST" = "0.0.0.0" ] || [ "$HOST" = "::" ] || [ "$HOST" = "*" ]; then
        NEW_HOST="127.0.0.1"
        MODE_LABEL="LOCAL"
    else
        NEW_HOST="0.0.0.0"
        MODE_LABEL="LAN"
    fi

    printf "\n%sSwitching to $MODE_LABEL mode (HOST=$NEW_HOST)...%s\n" "$GREEN" "$FG"
    update_config "HOST" "$NEW_HOST"
    restart_backend
}

get_ip() {
    if command -v ip >/dev/null 2>&1; then
        # Modern Linux: Get the IP used for the default route to avoid bridge/virtual IPs
        ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' || \
        ip -4 addr show scope global | grep -E 'inet ' | grep -v '127.0.0.1' | awk '{print $2}' | cut -d/ -f1 | head -n 1
    elif command -v hostname >/dev/null 2>&1 && hostname -I >/dev/null 2>&1; then
        # Traditional Linux
        hostname -I | awk '{print $1}'
    else
        # POSIX-ish fallback (BSD/macOS)
        ifconfig 2>/dev/null | grep -E 'inet ' | grep -vE '127.0.0.1|docker|vboxnet' | awk '/inet / {print $2}' | head -n 1 | sed 's/addr://'
    fi
}

launch_jvim() {
    printf "\n%sLaunching jvim editor...%s\n" "$GREEN" "$FG"
    "$JENOVA_ROOT/bin/jvim"
}

launch_webui() {
    local URL="http://${HOST}:${PORT}"
    printf "\n%sOpening Web UI at %s...%s\n" "$CYAN" "$URL" "$FG"
    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$URL" >/dev/null 2>&1 &
    elif command -v open >/dev/null 2>&1; then
        open "$URL" >/dev/null 2>&1 &
    else
        echo "Please open $URL in your browser."
        sleep 3
    fi
}

# в”Җв”Җ UI Components в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Detect terminal width, fallback to 60
get_term_width() {
    local w
    w=$(tput cols 2>/dev/null || echo 60)
    [ "$w" -gt 100 ] && w=100
    [ "$w" -lt 40 ] && w=40
    echo "$w"
}

draw_box() {
    local title="$1"
    local width="$2"
    local title_len=${#title}
    local content_width=$((width - 2))
    local left_pad=$(((content_width - title_len - 2) / 2))
    local right_pad=$((content_width - title_len - 2 - left_pad))
    
    printf "%sв”Ң%sв”җ%s\n" "$PURPLE" "$(printf 'в”Җ%.0s' $(seq 1 $content_width))" "$FG"
    printf "%sв”Ӯ%s%*s %s%s %*s %s%sв”Ӯ%s\n" "$PURPLE" "$BG" "$left_pad" "" "$BOLD$FG" "$title" "$right_pad" "" "$RESET$BG" "$PURPLE" "$FG"
    printf "%sв”ң%sв”Ө%s\n" "$PURPLE" "$(printf 'в”Җ%.0s' $(seq 1 $content_width))" "$FG"
}

draw_box_bottom() {
    local width="$1"
    local content_width=$((width - 2))
    printf "%sв””%sв”ҳ%s\n" "$PURPLE" "$(printf 'в”Җ%.0s' $(seq 1 $content_width))" "$FG"
}

# в”Җв”Җ Main Loop в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
selected=0
options=(
    "Start Backend"
    "Stop Backend"
    "Restart Backend"
    "Switch Mode (Local/LAN)"
    "Connect to Remote (Proxy)"
    "Launch J-Vim"
    "Launch Web UI"
    "Exit"
)
count=${#options[@]}

# Hide cursor
hide_cursor() { printf "\033[?25l"; }
show_cursor() { printf "\033[?25h"; }
enter_alt_screen() { printf "\033[?1049h"; }
exit_alt_screen() { printf "\033[?1049l"; }

trap 'show_cursor; exit_alt_screen; exit' INT TERM

load_config
enter_alt_screen
hide_cursor

while true; do
    WIDTH=$(get_term_width)
    IP=$(get_ip)
    printf "%s" "$CLEAR"
    echo ""
    draw_box "Jenova Cognitive Architecture" "$WIDTH"
    
    # Status Section
    printf "%sв”Ӯ%s %sSystem Status:%s %-*s %s%sв”Ӯ%s\n" "$PURPLE" "$BG" "$BOLD" "$FG" "$((WIDTH-19))" "" "$RESET$BG" "$PURPLE" "$FG"
    
    format_stat() {
        local lbl="$1"
        local val="$2"
        local plain_val="$3"
        local content_width=$((WIDTH - 2))
        local corrected_pad=$((content_width - 5 - ${#lbl} - ${#plain_val}))
        [ "$corrected_pad" -lt 0 ] && corrected_pad=0
        printf "%sв”Ӯ%s    %s%s%*s %s%sв”Ӯ%s\n" "$PURPLE" "$BG" "$lbl" "$val" "$corrected_pad" "" "$RESET$BG" "$PURPLE" "$FG"
    }
    
    if [ "$HOST" = "0.0.0.0" ] || [ "$HOST" = "::" ] || [ "$HOST" = "*" ]; then
        mode_raw="LAN (Accessible from other devices)"
    else
        mode_raw="LOCAL (Accessible from this device only)"
    fi
    
    format_stat "Backend: " "$(get_status)" "$(get_status_lbl)"
    format_stat "Mode:    " "$(get_mode)" "$mode_raw"
    if [ "$HOST" = "0.0.0.0" ] && [ -n "$IP" ]; then
        format_stat "LAN IP:  " "$IP" "$IP"
    fi
    format_stat "Host:    " "$HOST" "$HOST"
    format_stat "Port:    " "$PORT" "$PORT"
    format_stat "Storage: " "$HOME/Workspaces" "$HOME/Workspaces"
    printf "%sв”Ӯ%s %-*s %s%sв”Ӯ%s\n" "$PURPLE" "$BG" "$((WIDTH-2))" "" "$RESET$BG" "$PURPLE" "$FG"
    
    # Menu Section
    for ((i=0; i<count; i++)); do
        if [ $i -eq $selected ]; then
            printf "%sв”Ӯ%s  > %-*s %s%sв”Ӯ%s\n" "$PURPLE" "$SEL_BG$FG" "$((WIDTH-6))" "${options[$i]}" "$RESET$BG" "$PURPLE" "$FG"
        else
            printf "%sв”Ӯ%s    %-*s %s%sв”Ӯ%s\n" "$PURPLE" "$BG$FG" "$((WIDTH-6))" "${options[$i]}" "$RESET$BG" "$PURPLE" "$FG"
        fi
    done
    
    draw_box_bottom "$WIDTH"
    
    read -rsn1 key
    if [[ $key == "" ]]; then
        case "$selected" in
            0) exit_alt_screen; start_backend; enter_alt_screen ;;
            1) exit_alt_screen; stop_backend; enter_alt_screen ;;
            2) exit_alt_screen; restart_backend; enter_alt_screen ;;
            3) exit_alt_screen; toggle_mode; enter_alt_screen ;;
            4)
                exit_alt_screen
                show_cursor
                echo ""
                printf "  Enter Remote Server IP: "
                read -r REMOTE_IP
                if [ -n "$REMOTE_IP" ]; then
                    if is_valid_ip "$REMOTE_IP"; then
                        printf "\n%sConfiguring local backend to proxy inference to %s...%s\n" "$GREEN" "$REMOTE_IP" "$FG"
                        update_config "JENOVA_LLAMA_URL" "http://$REMOTE_IP:8081"
                        restart_backend
                    else
                        printf "\n%sError: Invalid IP address format.%s\n" "$RED" "$FG"
                        sleep 2
                    fi
                fi
                hide_cursor
                enter_alt_screen
                ;;
            5) exit_alt_screen; launch_jvim; enter_alt_screen ;;
            6) exit_alt_screen; launch_webui; enter_alt_screen ;;
            7) exit 0 ;;
        esac
    elif [[ $key == $'\x1b' ]]; then
        read -rsn2 -t 0.01 key
        case $key in
            '[A')
                selected=$((selected - 1))
                if [ $selected -lt 0 ]; then selected=$((count-1)); fi
                ;;
            '[B')
                selected=$((selected + 1))
                if [ $selected -ge $count ]; then selected=0; fi
                ;;
        esac
    fi
done
