#!/bin/sh
# build-llama: Llama.cpp source build wrapper (Vulkan + CUDA hybrid).
#
# Defaults:
#   - backend: hybrid (Vulkan + CUDA)
#   - build dir: <jenova>/external/llama.cpp/build
#   - config override: <jenova>/etc/jenova.local.conf
#
# Env overrides:
#   JENOVA_BACKEND=hybrid|vulkan|cuda|metal|cpu|auto
#   JENOVA_BUILD_DIR=/custom/path
#   JENOVA_THREADS=<int>
#   JENOVA_THREADS_BATCH=<int>
#   JENOVA_NGL_AGENT=all|<int>
#   JENOVA_FITT=<int>
#   JOBS=<int>

set -eu

_script="$0"
[ "${_script#*/*}" = "${_script}" ] && _script=$(command -v "$_script" 2>/dev/null || echo "$_script")
if command -v realpath >/dev/null 2>&1; then
    _script_dir=$(dirname "$(realpath "$_script")")
else
    # Fallback to manual symlink resolution if realpath is not available
    while [ -h "$_script" ]; do
        _target=$(readlink "$_script")
        case "$_target" in
            /*) _script="$_target" ;;
            *) _script="$(dirname "$_script")/$_target" ;;
        esac
    done
    _script_dir=$(dirname "$_script")
fi
JENOVA_ROOT="$(cd "${JENOVA_ROOT:-$_script_dir/..}" 2>/dev/null && pwd || echo "${JENOVA_ROOT:-$_script_dir/..}")"

if [ ! -d "$JENOVA_ROOT" ]; then
    echo "Error: JENOVA_ROOT ($JENOVA_ROOT) is not a valid directory." >&2
    exit 1
fi

LLAMA_DIR="$JENOVA_ROOT/external/llama.cpp"
BUILD_DIR="${JENOVA_BUILD_DIR:-$LLAMA_DIR/build}"
LOCAL_CONF_ETC="$JENOVA_ROOT/etc/jenova.local.conf"
LOCAL_CONF_BUILD="$LLAMA_DIR/build/jenova.local.conf"
LOCAL_CONF="$LOCAL_CONF_ETC"
BACKEND="${JENOVA_BACKEND:-hybrid}"

if [ ! -d "$LLAMA_DIR" ]; then
    echo "Error: external/llama.cpp directory not found at $LLAMA_DIR" >&2
    exit 1
fi

# Shared OS/hardware detection.
. "$JENOVA_ROOT/lib/detect-env.sh"

LOGICAL_THREADS="${JENOVA_CPU_THREADS:-1}"
PHYSICAL_THREADS="${JENOVA_PHYSICAL_THREADS:-1}"
THREADS="${JENOVA_THREADS:-$PHYSICAL_THREADS}"
THREADS_BATCH="${JENOVA_THREADS_BATCH:-$((PHYSICAL_THREADS + 2))}"
[ "$THREADS_BATCH" -gt "$LOGICAL_THREADS" ] && THREADS_BATCH="$LOGICAL_THREADS"
[ "$THREADS_BATCH" -lt "$THREADS" ] && THREADS_BATCH="$THREADS"

RAM_GIB="${JENOVA_RAM_GIB:-0}"
SWAP_GIB="${JENOVA_SWAP_GIB:-0}"

if [ -z "${JOBS:-}" ]; then
    JOBS="$LOGICAL_THREADS"
fi

if ! command -v cmake >/dev/null 2>&1; then
    echo "Error: cmake is required but was not found in PATH." >&2
    echo "Install it, then re-run this script." >&2
    exit 1
fi

GENERATOR="Unix Makefiles"
if command -v ninja >/dev/null 2>&1; then
    GENERATOR="Ninja"
fi

ENABLE_VULKAN=0
ENABLE_CUDA=0
ENABLE_METAL=0

case "$BACKEND" in
    vulkan)
        ENABLE_VULKAN=1
        ;;
    cuda)
        ENABLE_CUDA=1
        ;;
    metal)
        ENABLE_METAL=1
        ;;
    hybrid|both)
        ENABLE_VULKAN=1
        ENABLE_CUDA=1
        ;;
    cpu)
        ;;
    auto)
        if [ "$JENOVA_OS" = "macos" ]; then
            if [ "$JENOVA_ARCH" = "aarch64" ]; then
                ENABLE_METAL=1
            else
                if [ "${JENOVA_VULKAN_OK:-0}" = "1" ]; then
                    ENABLE_VULKAN=1
                fi
            fi
        else
            if command -v vulkaninfo >/dev/null 2>&1 && vulkaninfo --summary 2>/dev/null | grep -q "deviceName"; then
                ENABLE_VULKAN=1
            fi
            if command -v nvcc >/dev/null 2>&1; then
                ENABLE_CUDA=1
            fi
        fi
        ;;
    *)
        echo "Error: unsupported JENOVA_BACKEND='$BACKEND' (use auto|vulkan|cuda|metal|hybrid|cpu)" >&2
        exit 1
        ;;
esac

if [ "${ENABLE_VULKAN:-0}" -eq 1 ] && [ "${JENOVA_GLSLC_OK:-0}" = "0" ]; then
    echo "Error: Vulkan backend requested but glslc was not found." >&2
    echo "Install the Vulkan shader compiler, then rerun:" >&2
    case "${JENOVA_PKG_MGR:-none}" in
        pkg)    echo "  sudo pkg install shaderc" >&2 ;;
        pacman) echo "  sudo pacman -S shaderc" >&2 ;;
        apt)    echo "  sudo apt install google-shaderc" >&2 ;;
        dnf)    echo "  sudo dnf install glslc" >&2 ;;
        zypper) echo "  sudo zypper install shaderc" >&2 ;;
        brew)   echo "  brew install shaderc" >&2 ;;
        *)      echo "  Install the 'glslc' / 'shaderc' package for your OS" >&2 ;;
    esac
    exit 1
fi

if [ -n "${JENOVA_NGL_AGENT:-}" ]; then
    NGL_AGENT="$JENOVA_NGL_AGENT"
else
    if [ "${ENABLE_VULKAN:-0}" = "1" ] || [ "${ENABLE_CUDA:-0}" = "1" ] || [ "${ENABLE_METAL:-0}" = "1" ]; then
        NGL_AGENT=all
    else
        NGL_AGENT=0
    fi
fi

FIT_TARGET="${JENOVA_FITT:-768}"

echo "== Jenova external/llama.cpp build =="
echo "Root:         $JENOVA_ROOT"
echo "external/llama.cpp:    $LLAMA_DIR"
echo "Build dir:    $BUILD_DIR"
if [ "${ENABLE_VULKAN:-0}" = "1" ] && [ "${ENABLE_CUDA:-0}" = "1" ]; then
    EFFECTIVE_BACKEND="hybrid (Vulkan + CUDA)"
elif [ "${ENABLE_CUDA:-0}" = "1" ]; then
    EFFECTIVE_BACKEND="cuda"
elif [ "${ENABLE_VULKAN:-0}" = "1" ]; then
    EFFECTIVE_BACKEND="vulkan"
elif [ "${ENABLE_METAL:-0}" = "1" ]; then
    EFFECTIVE_BACKEND="metal"
else
    EFFECTIVE_BACKEND="cpu"
fi
echo "Backend:      $EFFECTIVE_BACKEND"
echo "Threads:      $THREADS (batch $THREADS_BATCH)"
echo "RAM / Swap:   ${RAM_GIB}GiB / ${SWAP_GIB}GiB"
echo "NGL_AGENT:    $NGL_AGENT"
echo "Generator:    $GENERATOR"
echo ""

mkdir -p "$BUILD_DIR"

_cleanup_on_fail() {
    _ec=$?
    if [ $_ec -ne 0 ]; then
        echo "Error: Build failed with exit code $_ec. Cleaning up partial build..." >&2
        [ -n "$BUILD_DIR" ] && rm -f "$BUILD_DIR/bin/llama-server"
    fi
    trap - EXIT
    exit $_ec
}
trap _cleanup_on_fail EXIT

set -- \
    -G "$GENERATOR" \
    -B "$BUILD_DIR" \
    -S "$LLAMA_DIR" \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_NATIVE=ON \
    -DGGML_LTO=ON \
    -DGGML_OPENMP=ON \
    -DBUILD_SHARED_LIBS=ON \
    -DGGML_CUDA=OFF \
    -DGGML_VULKAN=OFF \
    -DGGML_METAL=OFF \
    "$@"

if [ "${ENABLE_VULKAN:-0}" = "1" ]; then
    set -- "$@" -DGGML_VULKAN=ON
fi

if [ "${ENABLE_CUDA:-0}" = "1" ]; then
    set -- "$@" -DGGML_CUDA=ON
fi

if [ "${ENABLE_METAL:-0}" = "1" ]; then
    set -- "$@" -DGGML_METAL=ON
fi

cmake "$@"
cmake --build "$BUILD_DIR" --config Release -j "$JOBS" --target llama-server

LLAMA_SERVER="$BUILD_DIR/bin/llama-server"
if [ ! -x "$LLAMA_SERVER" ]; then
    echo "Error: build completed but llama-server is missing at $LLAMA_SERVER" >&2
    exit 1
fi

if [ -e "$LOCAL_CONF_ETC" ]; then
    if [ ! -w "$LOCAL_CONF_ETC" ]; then
        LOCAL_CONF="$LOCAL_CONF_BUILD"
    fi
elif [ ! -w "$JENOVA_ROOT/etc" ]; then
    LOCAL_CONF="$LOCAL_CONF_BUILD"
fi

mkdir -p "$(dirname "$LOCAL_CONF")"

DEVICES=""
GENERATED_TENSOR_SPLIT=""

append_devices() {
    _prefix=$1
    _count=$2
    [ "$_count" -le 0 ] && return
    _i=0
    while [ "$_i" -lt "$_count" ]; do
        if [ -n "$DEVICES" ]; then DEVICES="$DEVICES,"; fi
        DEVICES="${DEVICES}${_prefix}${_i}"
        _i=$((_i + 1))
    done
}

if [ "${ENABLE_VULKAN:-0}" = "1" ]; then
    _vcount=0
    if command -v vulkaninfo >/dev/null 2>&1; then
        _vcount=$(vulkaninfo --summary 2>/dev/null | grep -c "GPU[0-9]:" || true)
    fi
    if [ "$_vcount" -eq 0 ]; then _vcount=1; fi
    append_devices "Vulkan" "$_vcount"
fi

if [ "${ENABLE_CUDA:-0}" = "1" ]; then
    _ccount=0
    if command -v nvidia-smi >/dev/null 2>&1; then
        _ccount=$(nvidia-smi -L 2>/dev/null | grep -c "GPU [0-9]:" || true)
    fi
    if [ "$_ccount" -eq 0 ]; then _ccount=1; fi
    append_devices "CUDA" "$_ccount"
fi

if [ "${ENABLE_METAL:-0}" = "1" ]; then
    append_devices "Metal" 1
fi

SUGGESTED_MODEL="Qwen3.5-4B-Q6_K.gguf"
if [ "${ENABLE_VULKAN:-0}" = "1" ] && [ "${ENABLE_CUDA:-0}" = "1" ]; then
    SUGGESTED_MODEL="Qwen3.5-9B-Q4_K_M.gguf"
fi

_llama_server_conf="$LLAMA_SERVER"
if [ -n "$JENOVA_ROOT" ]; then
    case "$LLAMA_SERVER" in
        "$JENOVA_ROOT"/*) _llama_server_conf="\$JENOVA_ROOT/${LLAMA_SERVER#"$JENOVA_ROOT"/}" ;;
    esac
fi

cat > "$LOCAL_CONF" <<EOF
#!/bin/sh
# Auto-generated by bin/build-llama — host-specific overrides for Jenova.
# Suggested model for this $([ "${ENABLE_VULKAN:-0}" = "1" ] && [ "${ENABLE_CUDA:-0}" = "1" ] && echo "dual-GPU " || echo "")build: $SUGGESTED_MODEL

LLAMA_SERVER="${_llama_server_conf}"
THREADS="\${JENOVA_THREADS:-$THREADS}"
THREADS_BATCH="\${JENOVA_THREADS_BATCH:-$THREADS_BATCH}"
NGL_AGENT="\${JENOVA_NGL_AGENT:-$NGL_AGENT}"
FIT_TARGET="\${JENOVA_FITT:-$FIT_TARGET}"
KV_CACHE_TYPE="\${JENOVA_KV_TYPE:-q8_0}"
EOF

if [ -n "$DEVICES" ]; then
cat >> "$LOCAL_CONF" <<EOF
DEVICES="\${JENOVA_DEVICES:-$DEVICES}"
TENSOR_SPLIT="\${JENOVA_TS:-$GENERATED_TENSOR_SPLIT}"
EOF
fi

if [ "${ENABLE_VULKAN:-0}" = "1" ]; then
cat >> "$LOCAL_CONF" <<'EOF'
# Allow Vulkan backend to fallback to system memory under pressure.
GGML_VK_ALLOW_SYSMEM_FALLBACK="${GGML_VK_ALLOW_SYSMEM_FALLBACK:-1}"
EOF
fi

if [ "${ENABLE_CUDA:-0}" = "1" ]; then
cat >> "$LOCAL_CONF" <<'EOF'
# CUDA-specific settings
GGML_CUDA_DMMV_POOL_SIZE="${GGML_CUDA_DMMV_POOL_SIZE:-512}"
EOF
fi

echo ""
echo "Build complete: $LLAMA_SERVER"
echo "Runtime overrides written: $LOCAL_CONF"
echo ""
if [ "$LOCAL_CONF" = "$LOCAL_CONF_ETC" ]; then
    echo "NOTE: $LOCAL_CONF is auto-generated and gitignored."
    echo "      See etc/jenova.local.conf.example for template."
fi
echo ""
echo "Next:"
echo "  $JENOVA_ROOT/bin/jenova-ca restart"
